#!/usr/bin/env python3
# SPDX-License-Identifier: GPL-3.0-only
"""
Toggle DT510 digital outputs DO1–DO4 together (GPIO1_IO06–09 → gpiochip0 lines 6–9).

Default period: 10 ms low / 10 ms high (50 Hz full cycle). Press Ctrl+C to stop.

Requires Linux libgpiod Python bindings (image RDEPENDS: python3-gpiod).
Run as root: sudo dt510-dio-toggle-outputs

Installed to sbindir by board-scripts on imx8mm-jaguar-dt510 (pulls in python3-gpiod).
"""

from __future__ import annotations

import argparse
import sys
import time

CHIP_PATH = "/dev/gpiochip0"
OUTPUT_LINES = (6, 7, 8, 9)


def _toggle_v2(half_period_s: float) -> None:
    import gpiod

    Val = gpiod.line.Value
    cfg = {
        ln: gpiod.LineSettings(direction=gpiod.line.Direction.OUTPUT)
        for ln in OUTPUT_LINES
    }
    with gpiod.request_lines(
        CHIP_PATH,
        consumer="dt510-dio-toggle",
        config=cfg,
    ) as req:
        active = False
        while True:
            active = not active
            val = Val.ACTIVE if active else Val.INACTIVE
            req.set_values({ln: val for ln in OUTPUT_LINES})
            time.sleep(half_period_s)


def _toggle_v1(half_period_s: float) -> None:
    import gpiod

    chip = gpiod.Chip(CHIP_PATH)
    lines = chip.get_lines(OUTPUT_LINES)
    lines.request(consumer="dt510-dio-toggle", type=gpiod.LINE_REQ_DIR_OUT)
    val = 0
    try:
        while True:
            lines.set_values([val] * len(OUTPUT_LINES))
            val = 1 - val
            time.sleep(half_period_s)
    finally:
        lines.release()
        chip.close()


def main() -> int:
    p = argparse.ArgumentParser(description="Toggle DT510 DO1–DO4 (gpiochip0 lines 6–9).")
    p.add_argument(
        "-p",
        "--half-period-ms",
        type=float,
        default=10.0,
        help="Half-period in ms (each output level time); default 10 → 10 ms high, 10 ms low.",
    )
    args = p.parse_args()
    half_s = max(args.half_period_ms, 0.1) / 1000.0

    try:
        try:
            _toggle_v2(half_s)
        except (ImportError, AttributeError, TypeError):
            try:
                _toggle_v1(half_s)
            except ImportError:
                print(
                    "dt510-dio-toggle-outputs: need libgpiod Python bindings "
                    "(install python3-gpiod on the image, or add it to board-scripts RDEPENDS).",
                    file=sys.stderr,
                )
                return 1
    except KeyboardInterrupt:
        print("\nStopped.")
        return 0
    return 0


if __name__ == "__main__":
    sys.exit(main())
