#!/bin/sh
# SPDX-License-Identifier: MIT
#
# Pulse NEO-M9V GNSS_RES# (gpiochip3 / GPIO4_IO29, active-low).
# pinctrl pull-up holds reset deasserted when idle; assert ≥50 ms then release.
#
# Usage: sudo dt510-gnss-reset-pulse

set -e

CHIP=gpiochip3
LINE="gnss-res#"

if [ "$(id -u)" -ne 0 ]; then
	echo "Run as root: sudo $0" >&2
	exit 1
fi

if ! command -v gpioset >/dev/null 2>&1; then
	echo "gpioset not found (libgpiod-tools)" >&2
	exit 1
fi

gpioset -c "$CHIP" --active-low "${LINE}=1"
sleep 0.05
gpioset -c "$CHIP" --mode=exit --active-low "${LINE}=0"
