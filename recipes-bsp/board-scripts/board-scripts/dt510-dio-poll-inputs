#!/bin/sh
# SPDX-License-Identifier: GPL-3.0-only
#
# Poll DT510 digital inputs DI1–DI4 on gpiochip0 (GPIO1).
#
# Mapping (see imx8mm-jaguar-dt510.dts &gpio1 gpio-line-names):
#   DI1 = GPIO1_IO0  (offset 0)  call-request
#   DI2 = GPIO1_IO1  (offset 1)  emergency
#   DI3 = GPIO1_IO4  (offset 4)  ptt
#   DI4 = GPIO1_IO5  (offset 5)  dio-input-4
#
# Outputs DO1–DO4 use offsets 6–9 (dt510-dio-toggle-outputs); this script
# only reads DI lines and does not claim them.
#
# Usage: sudo dt510-dio-poll-inputs [interval_seconds] [--once]

CHIP=gpiochip0
# Do not name this LINES — bash exports $LINES (terminal height, often 61) and
# gpioget would then request offset 61 on gpiochip0 after the first poll.
DIO_OFFSETS="0 1 4 5"

if [ "$(id -u)" -ne 0 ]; then
	echo "Run as root: sudo $0" >&2
	exit 1
fi

if ! command -v gpioget >/dev/null 2>&1; then
	echo "gpioget not found (libgpiod-tools)" >&2
	exit 1
fi

INTERVAL=0.5
ONCE=0
for a in "$@"; do
	case "$a" in
	--once) ONCE=1 ;;
	'') ;;
	*[!0-9.]*) ;;
	*) INTERVAL="$a" ;;
	esac
done

poll_once() {
	# libgpiod v2 defaults to keyword values ("0"=inactive …); --numeric gives 0/1.
	# shellcheck disable=SC2086
	if ! set -- $(gpioget --numeric -c "$CHIP" $DIO_OFFSETS 2>/dev/null); then
		ts=$(date '+%Y-%m-%d %H:%M:%S')
		printf '%s  DI1(IO0)=?  DI2(IO1)=?  DI3(IO4)=?  DI4(IO5)=?  (gpioget failed)\n' "$ts" >&2
		return 1
	fi
	v0=${1:-?}
	v1=${2:-?}
	v4=${3:-?}
	v5=${4:-?}
	ts=$(date '+%Y-%m-%d %H:%M:%S')
	printf '%s  DI1(call-request)=%s  DI2(emergency)=%s  DI3(ptt)=%s  DI4(dio-input-4)=%s\n' \
		"$ts" "$v0" "$v1" "$v4" "$v5"
}

printf '# DT510 GPIO inputs (%s offsets %s) — values 0/1 = inactive/active (libgpiod --numeric)\n' "$CHIP" "$DIO_OFFSETS"
while true; do
	poll_once
	if [ "$ONCE" -eq 1 ]; then
		break
	fi
	sleep "$INTERVAL"
done
