From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Dynamic Devices <support@dynamicdevices.co.uk>
Date: Sun, 31 May 2026 00:00:00 +0000
Subject: [PATCH] imx9: stub check_secondary_cnt_set for SCMI SPL link

Factory u-boot-fio SPL references check_secondary_cnt_set while the SCMI
code path only defines scmi_get_* helpers. Stub the symbol for imx9+SCMI.
---
 arch/arm/mach-imx/image-container.c | 10 ++++++++++
 1 file changed, 10 insertions(+)

--- a/arch/arm/mach-imx/image-container.c	2026-05-31 23:16:30.813687707 +0100
+++ b/arch/arm/mach-imx/image-container.c	2026-05-31 23:16:30.813687707 +0100
@@ -2,6 +2,15 @@
 
 #endif
 
+#if IS_ENABLED(CONFIG_ARCH_IMX9) && IS_ENABLED(CONFIG_SCMI_FIRMWARE)
+bool check_secondary_cnt_set(unsigned long *set_off)
+{
+	if (set_off)
+		*set_off = 0;
+	return false;
+}
+#endif
+
 static unsigned long get_boot_device_offset(void *dev, int dev_type)
 {
 	unsigned long offset = 0, sec_set_off = 0;
