/*
 * i.MX8MM Jaguar DT510 — canonical device tree source (Tier A2).
 *
 * recipes-kernel/linux/linux-lmp-fslc-imx/imx8mm-jaguar-dt510.dts is a symlink to this file (Tier A1).
 *
 * Hardware SSOT: VIX DT510 pinout / hardware spec (Google Doc, first cut — revise on schematic proof).
 * Tool-generated review material (not built): docs/reference/dt510-ollie-tool-generated/
 * Bring-up plan & tiers: docs/DT510-BSP-PROJECT-PLAN.md
 */

#include "freescale/imx8mm-evkb.dts"
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>
#include <dt-bindings/interrupt-controller/irq.h>
#include <dt-bindings/clock/imx8mm-clock.h>

/*
 * imx8mm-evkb.dts: PCA9450 @ i2c1 @0x25 (nxp,pca9450a), not BD71847 — matches DT510 hardware.
 * Fragments below duplicate imx8mm-evk.dts board content omitted by evkb.dtsi-only include so
 * DDRC OPP and USDHC3 eMMC + pinmux stay as they were with imx8mm-evk.dts (FlexSPI omitted — unused on DT510).
 */

&ddrc {
	operating-points-v2 = <&ddrc_opp_table>;

	ddrc_opp_table: opp-table {
		compatible = "operating-points-v2";

		opp-25000000 {
			opp-hz = /bits/ 64 <25000000>;
		};

		opp-100000000 {
			opp-hz = /bits/ 64 <100000000>;
		};

		opp-750000000 {
			opp-hz = /bits/ 64 <750000000>;
		};
	};
};

&usdhc3 {
	assigned-clocks = <&clk IMX8MM_CLK_USDHC3_ROOT>;
	assigned-clock-rates = <400000000>;
	pinctrl-names = "default", "state_100mhz", "state_200mhz";
	pinctrl-0 = <&pinctrl_usdhc3>;
	pinctrl-1 = <&pinctrl_usdhc3_100mhz>;
	pinctrl-2 = <&pinctrl_usdhc3_200mhz>;
	bus-width = <8>;
	non-removable;
	status = "okay";
};

&iomuxc {
	pinctrl_usdhc3: usdhc3grp {
		fsl,pins = <
			MX8MM_IOMUXC_NAND_WE_B_USDHC3_CLK               0x190
			MX8MM_IOMUXC_NAND_WP_B_USDHC3_CMD               0x1d0
			MX8MM_IOMUXC_NAND_DATA04_USDHC3_DATA0           0x1d0
			MX8MM_IOMUXC_NAND_DATA05_USDHC3_DATA1           0x1d0
			MX8MM_IOMUXC_NAND_DATA06_USDHC3_DATA2           0x1d0
			MX8MM_IOMUXC_NAND_DATA07_USDHC3_DATA3           0x1d0
			MX8MM_IOMUXC_NAND_RE_B_USDHC3_DATA4             0x1d0
			MX8MM_IOMUXC_NAND_CE2_B_USDHC3_DATA5            0x1d0
			MX8MM_IOMUXC_NAND_CE3_B_USDHC3_DATA6            0x1d0
			MX8MM_IOMUXC_NAND_CLE_USDHC3_DATA7              0x1d0
			MX8MM_IOMUXC_NAND_CE1_B_USDHC3_STROBE           0x190
		>;
	};

	pinctrl_usdhc3_100mhz: usdhc3-100mhzgrp {
		fsl,pins = <
			MX8MM_IOMUXC_NAND_WE_B_USDHC3_CLK               0x194
			MX8MM_IOMUXC_NAND_WP_B_USDHC3_CMD               0x1d4
			MX8MM_IOMUXC_NAND_DATA04_USDHC3_DATA0           0x1d4
			MX8MM_IOMUXC_NAND_DATA05_USDHC3_DATA1           0x1d4
			MX8MM_IOMUXC_NAND_DATA06_USDHC3_DATA2           0x1d4
			MX8MM_IOMUXC_NAND_DATA07_USDHC3_DATA3           0x1d4
			MX8MM_IOMUXC_NAND_RE_B_USDHC3_DATA4             0x1d4
			MX8MM_IOMUXC_NAND_CE2_B_USDHC3_DATA5            0x1d4
			MX8MM_IOMUXC_NAND_CE3_B_USDHC3_DATA6            0x1d4
			MX8MM_IOMUXC_NAND_CLE_USDHC3_DATA7              0x1d4
			MX8MM_IOMUXC_NAND_CE1_B_USDHC3_STROBE           0x194
		>;
	};

	pinctrl_usdhc3_200mhz: usdhc3-200mhzgrp {
		fsl,pins = <
			MX8MM_IOMUXC_NAND_WE_B_USDHC3_CLK               0x196
			MX8MM_IOMUXC_NAND_WP_B_USDHC3_CMD               0x1d6
			MX8MM_IOMUXC_NAND_DATA04_USDHC3_DATA0           0x1d6
			MX8MM_IOMUXC_NAND_DATA05_USDHC3_DATA1           0x1d6
			MX8MM_IOMUXC_NAND_DATA06_USDHC3_DATA2           0x1d6
			MX8MM_IOMUXC_NAND_DATA07_USDHC3_DATA3           0x1d6
			MX8MM_IOMUXC_NAND_RE_B_USDHC3_DATA4             0x1d6
			MX8MM_IOMUXC_NAND_CE2_B_USDHC3_DATA5            0x1d6
			MX8MM_IOMUXC_NAND_CE3_B_USDHC3_DATA6            0x1d6
			MX8MM_IOMUXC_NAND_CLE_USDHC3_DATA7              0x1d6
			MX8MM_IOMUXC_NAND_CE1_B_USDHC3_STROBE           0x196
		>;
	};
};

/ {
	model = "i.MX8MM Jaguar DT510 board";
	compatible = "fsl,imx8mm-jaguar-dt510", "fsl,imx8mm-evkb", "fsl,imx8mm-evk", "fsl,imx8mm";

	// Regulators
	/* TAS6424 DVDD: 3.3 V placeholder — **@ohull456 to confirm** nominal vs schematic (SSOT). */
	vddext: regulator-vddext {
		compatible = "regulator-fixed";
		regulator-name = "VDDEXT_3V3";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
	};

	/*
	 * TAS6424 VBAT + PVDD: driver requires distinct phandles; single fixed rail for both.
	 * **12 V placeholder — @ohull456 to confirm** net names / nominal voltage per BOM.
	 * Ollie (issue #2): rails always-on, no software sequencing — regulator-always-on is OK.
	 */
	tas6424_hi_rail: regulator-tas6424-hi {
		compatible = "regulator-fixed";
		regulator-name = "TAS6424_VBAT_PVDD";
		regulator-min-microvolt = <12000000>;
		regulator-max-microvolt = <12000000>;
		regulator-always-on;
	};

	/* Tier C2: TAS6424 class-D — CPU (SAI1) is BCLK/FS master; codec is slave (driver CBC_CFC). */
	sound-tas6424 {
		compatible = "simple-audio-card";
		simple-audio-card,name = "tas6424-classd";
		simple-audio-card,format = "i2s";
		simple-audio-card,frame-master = <&tas6424_cpu_dai>;
		simple-audio-card,bitclock-master = <&tas6424_cpu_dai>;
		simple-audio-card,widgets =
			"Speaker", "Speaker";
		simple-audio-card,routing =
			"Speaker", "OUT";

		tas6424_cpu_dai: simple-audio-card,cpu {
			sound-dai = <&sai1>;
		};

		simple-audio-card,codec {
			sound-dai = <&tas6424>;
			clocks = <&clk IMX8MM_CLK_SAI1_ROOT>;
		};
	};

	sound-tas2563 {
		compatible = "simple-audio-card";
		simple-audio-card,name = "tas2563-audio";
		simple-audio-card,format = "i2s";
		simple-audio-card,frame-master = <&cpudai2>;
		simple-audio-card,bitclock-master = <&cpudai2>;

		// TAS2562 driver routing (simpler than TAS2781)
		// The TAS2562 driver doesn't use DMIC widgets
		simple-audio-card,widgets =
			"Speaker", "Speaker";
		simple-audio-card,routing =
			"Speaker", "OUT";

		cpudai2: simple-audio-card,cpu {
			sound-dai = <&sai3>;
			dai-tdm-slot-num = <4>;  /* Increase to 4 slots for Profile 8 */
			dai-tdm-slot-width = <32>;
		};

		simple-audio-card,codec {
			sound-dai = <&tas2563>;
			clocks = <&clk IMX8MM_CLK_SAI3_ROOT>;
		};
	};

	/*
	 * TAC5301-Q1 @ I2C2 0x50 — analog mono codec (Ollie SSOT).
	 * SAI6: pads from `docs/reference/dt510-ollie-tool-generated/pin_mux.dts` (BOARD_InitPins).
	 * Requires kernel ASoC support for ti,tac5301 (TAC5x1x family) when enabled in defconfig.
	 */
	sound-tac5301 {
		compatible = "simple-audio-card";
		simple-audio-card,name = "tac5301-analog";
		simple-audio-card,format = "i2s";
		simple-audio-card,frame-master = <&tac5301_cpu_dai>;
		simple-audio-card,bitclock-master = <&tac5301_cpu_dai>;
		simple-audio-card,widgets =
			"Speaker", "Speaker";
		simple-audio-card,routing =
			"Speaker", "OUT";

		tac5301_cpu_dai: simple-audio-card,cpu {
			sound-dai = <&sai6>;
		};

		simple-audio-card,codec {
			sound-dai = <&tac5301>;
			clocks = <&clk IMX8MM_CLK_SAI6_ROOT>;
		};
	};

	// MICFIL Audio Configuration (for original PDM hardware)
	sound-micfil {
		compatible = "fsl,imx-audio-card";
		model = "micfil-audio";
		status = "disabled"; /* &micfil off — SAI1 muxed for TAS6424 per SSOT */
		pri-dai-link {
			link-name = "micfil hifi";
			format = "i2s";
			cpu {
				sound-dai = <&micfil>;
			};
		};
	};

	sound-wm8524 {
		status = "disabled";
	};

	sound-ak4458 {
		status = "disabled";
	};

	sound-spdif {
		status = "disabled";
	};

	sound-bt-sco {
		status = "disabled";
	};

	// Disable M4 core to prevent resource conflicts
	imx8mm-cm4 {
		compatible = "fsl,imx8mm-cm4";
		status = "disabled";
	};

	// RDC configuration for UART4 resource assignment
	// This ensures UART4 is properly assigned to A53 domain before UART driver probes
	rdc: rdc@303d0000 {
		compatible = "fsl,imx8mm-rdc";
		reg = <0x0 0x303d0000 0x0 0x10000>;
		status = "okay";

		// Configure UART4 for A53 domain (domain 0) access
		// This must complete before serial driver initialization
		fsl,rdc-config = <
			0x44  0x3  // UART4 PDAP: Domain 0 (A53) read/write access
		>;
	};

	sw-keys {
		compatible = "gpio-keys";
		status = "enabled";

		sw1: key-act {
			label = "Key Act";
			linux,code = <BTN_SELECT>;
			gpios = <&gpio3 6 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
			interrupt-parent = <&gpio3>;
			interrupt = <6 IRQ_TYPE_EDGE_FALLING>;
		};
	};

	/* Tier B1: BQ25792 monitored-battery model — tune from SSOT / pack (1S placeholder). */
	battery_dt510: battery-dt510 {
		compatible = "simple-battery";
		constant-charge-voltage-max-microvolt = <4200000>;
		constant-charge-current-max-microamp = <2000000>;
		charge-term-current-microamp = <160000>;
	};
};

&iomuxc {
	pinctrl-names = "default";
	/* E1 bisect: Tier B2 gpio1_dio reverted — was hog+gpio1_dio+bq25792_chgr_int */
	pinctrl-0 = <&pinctrl_hog>, <&pinctrl_bq25792_chgr_int>;

	// TODO: Break these out better?
	pinctrl_hog: hoggrp {
		fsl,pins = <
			MX8MM_IOMUXC_SD1_DATA4_GPIO2_IO6	0x140  // WL_WAKE_DEV
			MX8MM_IOMUXC_SD1_DATA5_GPIO2_IO7	0x140  // BT_WAKE_DEV
			MX8MM_IOMUXC_SD1_DATA6_GPIO2_IO8	0x000  // LTE_RESET
			MX8MM_IOMUXC_NAND_CE0_B_GPIO3_IO1	0x140  // FUL_CARD_POWER_OFF#
			MX8MM_IOMUXC_NAND_DATA01_GPIO3_IO7	0x140  // WIFI_PD#
			MX8MM_IOMUXC_NAND_DATA02_GPIO3_IO8	0x140  // BT_WAKE_HOST
			MX8MM_IOMUXC_NAND_DATA03_GPIO3_IO9	0x140  // BT_RST#
			/* SAI1_RXD4 / RXD7 / …: not hogged — those pads are used by board SSOT for TAS6424 (only
			 * the 5-line I2S out is in `pinctrl_sai1_tas6424`), SAI6, and BQ CHGR on RXD7
			 * (`pinctrl_bq25792_chgr_int`); see Ollie `docs/reference/dt510-ollie-tool-generated/pin_mux.dts`. */
			MX8MM_IOMUXC_SPDIF_RX_GPIO5_IO4		0x140  // CODEC_SD#
			// ZB_INT and ZB_RST# removed from hog - managed by ZBoss muxer
		>;
	};

	// Zigbee GPIO pins - not hogged, available for ZBoss muxer
	pinctrl_zigbee: zigbeegrp {
		fsl,pins = <
			MX8MM_IOMUXC_SAI2_RXC_GPIO4_IO22		0x140  // ZB_INT
			MX8MM_IOMUXC_SD1_STROBE_GPIO2_IO11		0x140  // ZB_RST#
		>;
	};

	pinctrl_ecspi1: ecspi1grp {
		fsl,pins = <
			MX8MM_IOMUXC_ECSPI1_SS0_GPIO5_IO9		0x140  // Increased drive strength
			MX8MM_IOMUXC_ECSPI1_SCLK_ECSPI1_SCLK		0x140  // Increased drive strength
			MX8MM_IOMUXC_ECSPI1_MISO_ECSPI1_MISO		0x140  // Increased drive strength
			MX8MM_IOMUXC_ECSPI1_MOSI_ECSPI1_MOSI		0x140  // Increased drive strength
		>;
	};

	pinctrl_sai2: sai2grp {
		fsl,pins = <
			MX8MM_IOMUXC_SAI2_MCLK_SAI2_MCLK		0xd6
			MX8MM_IOMUXC_SAI2_TXFS_SAI2_TX_SYNC		0xd6
			MX8MM_IOMUXC_SAI2_TXC_SAI2_TX_BCLK		0xd6
			MX8MM_IOMUXC_SAI2_TXD0_SAI2_TX_DATA0		0xd6
			MX8MM_IOMUXC_SAI2_RXD0_SAI2_RX_DATA0		0xd6
		>;
	};

	pinctrl_sai3: sai3grp {
		fsl,pins = <
			MX8MM_IOMUXC_SAI3_TXFS_SAI3_TX_SYNC		0xd6    // Frame sync
			MX8MM_IOMUXC_SAI3_TXC_SAI3_TX_BCLK		0xd6    // Bit clock
			MX8MM_IOMUXC_SAI3_MCLK_SAI3_MCLK		0xd6    // Master clock
			MX8MM_IOMUXC_SAI3_TXD_SAI3_TX_DATA0		0xd6    // Transmit (playback)
			MX8MM_IOMUXC_SAI3_RXD_SAI3_RX_DATA0		0xd6    // Receive (from TAS2563 mics)
			MX8MM_IOMUXC_SPDIF_EXT_CLK_GPIO5_IO5		0xd6    // Audio codec interrupt
		>;
	};

	/*
	 * TAS6424E — GPIO1 sideband (I2C control + driver; separate from SAI1 audio bus).
	 * Mux: GPIO. Pad 0x116: matches `docs/reference/dt510-ollie-tool-generated/pin_mux.dts` GPIO1 block.
	 *	 GPIO1_IO10: AMP_STBY# — output, active-low (standby-gpios on tas6424@6a)
	 *	 GPIO1_IO11: AMP_MUTE# — output, active-low (mute-gpios on tas6424@6a)
	 *	 GPIO1_IO12: AMP_FAULT# — input, active-low (not bound in driver; may poll via I2C)
	 *	 GPIO1_IO13: AMP_WARN# — input, active-low (same)
	 * Do not list these balls again under `pinctrl_sai1_tas6424` (duplicate pinctrl / wrong pad class).
	 */
	pinctrl_tas6424_gpio: tas6424gpiogrp {
		fsl,pins = <
			MX8MM_IOMUXC_GPIO1_IO10_GPIO1_IO10	0x116
			MX8MM_IOMUXC_GPIO1_IO11_GPIO1_IO11	0x116
			MX8MM_IOMUXC_GPIO1_IO12_GPIO1_IO12	0x116
			MX8MM_IOMUXC_GPIO1_IO13_GPIO1_IO13	0x116
		>;
	};

	/*
	 * B1 SSOT: CHGR_INT# from BQ25792 → SAI1_RXD7 / GPIO4_IO9 (active-low). Mux as GPIO, not SAI.
	 * Conflicts with prior LP5024 enable-gpios on gpio4 9 — LED driver leaves EN to hardware.
	 */
	pinctrl_bq25792_chgr_int: bq25792_chgr_int_grp {
		fsl,pins = <
			MX8MM_IOMUXC_SAI1_RXD7_GPIO4_IO9	0x140  /* CHGR_INT# */
		>;
	};

	/*
	 * TAS6424E — SAI1 I2S to codec (5 pins only, per product spec).
	 *	 SAI1_MCLK, SAI1_TX_SYNC, SAI1_TX_BCLK, SAI1_TX_DATA0, SAI1_TX_DATA1
	 * Pad config follows Ollie `pin_mux.dts` BOARD_InitPins: 0x116 for MCLK/BCLK/DATA, 0x1916 for
	 * frame sync (same 0x1916 pattern as ENET TX_CTL in this file — steeper drive / skew).
	 * Do not merge GPIO1_IO10–13 here: those stay in `pinctrl_tas6424_gpio` with 0x116.
	 */
	pinctrl_sai1_tas6424: sai1tas6424grp {
		fsl,pins = <
			MX8MM_IOMUXC_SAI1_MCLK_SAI1_MCLK		0x116
			MX8MM_IOMUXC_SAI1_TXFS_SAI1_TX_SYNC		0x1916
			MX8MM_IOMUXC_SAI1_TXC_SAI1_TX_BCLK		0x116
			MX8MM_IOMUXC_SAI1_TXD0_SAI1_TX_DATA0	0x116
			MX8MM_IOMUXC_SAI1_TXD1_SAI1_TX_DATA1	0x116
		>;
	};

	/*
	 * TAC5301-Q1 ↔ SAI6 (Ollie SSOT). Pad config 0x116 matches BOARD_InitPins in
	 * `docs/reference/dt510-ollie-tool-generated/pin_mux.dts`.
	 */
	pinctrl_sai6_tac5301: sai6_tac5301_grp {
		fsl,pins = <
			MX8MM_IOMUXC_SAI1_RXD6_SAI6_TX_SYNC		0x116
			MX8MM_IOMUXC_SAI1_RXD4_SAI6_TX_BCLK		0x116
			MX8MM_IOMUXC_SAI1_RXD5_SAI6_TX_DATA0		0x116
			MX8MM_IOMUXC_SAI1_TXD5_SAI6_RX_DATA0		0x116
		>;
	};

	/* SAI1_TXD2 → GPIO4_IO14 — codec sideband (Ollie SSOT); used with tac5301 reset-gpios. */
	pinctrl_tac5301_gpio: tac5301_gpio_grp {
		fsl,pins = <
			MX8MM_IOMUXC_SAI1_TXD2_GPIO4_IO14		0x116
		>;
	};

	pinctrl_uart1: uart1grp {
		fsl,pins = <
			MX8MM_IOMUXC_UART1_RXD_UART1_DCE_RX		0x140
			MX8MM_IOMUXC_UART1_TXD_UART1_DCE_TX		0x140
			MX8MM_IOMUXC_UART3_TXD_UART1_DCE_RTS_B		0x140
			MX8MM_IOMUXC_UART3_RXD_UART1_DCE_CTS_B		0x140
		>;
	};

	pinctrl_uart4: uart4grp {
		fsl,pins = <
			MX8MM_IOMUXC_UART4_RXD_UART4_DCE_RX		0x140
			MX8MM_IOMUXC_UART4_TXD_UART4_DCE_TX		0x140
		>;
	};

	pinctrl_usdhc2: usdhc2grp {
		fsl,pins = <
			MX8MM_IOMUXC_SD2_CLK_USDHC2_CLK		0x190
			MX8MM_IOMUXC_SD2_CMD_USDHC2_CMD		0x1d0
			MX8MM_IOMUXC_SD2_DATA0_USDHC2_DATA0		0x1d0
			MX8MM_IOMUXC_SD2_DATA1_USDHC2_DATA1		0x1d0
			MX8MM_IOMUXC_SD2_DATA2_USDHC2_DATA2		0x1d0
			MX8MM_IOMUXC_SD2_DATA3_USDHC2_DATA3		0x1d0
		>;
	};

	pinctrl_usdhc2_100mhz: usdhc2-100mhzgrp {
		fsl,pins = <
			MX8MM_IOMUXC_SD2_CLK_USDHC2_CLK		0x194
			MX8MM_IOMUXC_SD2_CMD_USDHC2_CMD		0x1d4
			MX8MM_IOMUXC_SD2_DATA0_USDHC2_DATA0		0x1d4
			MX8MM_IOMUXC_SD2_DATA1_USDHC2_DATA1		0x1d4
			MX8MM_IOMUXC_SD2_DATA2_USDHC2_DATA2		0x1d4
			MX8MM_IOMUXC_SD2_DATA3_USDHC2_DATA3		0x1d4
		>;
	};

	pinctrl_usdhc2_200mhz: usdhc2-200mhzgrp {
		fsl,pins = <
			MX8MM_IOMUXC_SD2_CLK_USDHC2_CLK		0x196
			MX8MM_IOMUXC_SD2_CMD_USDHC2_CMD		0x1d6
			MX8MM_IOMUXC_SD2_DATA0_USDHC2_DATA0		0x1d6
			MX8MM_IOMUXC_SD2_DATA1_USDHC2_DATA1		0x1d6
			MX8MM_IOMUXC_SD2_DATA2_USDHC2_DATA2		0x1d6
			MX8MM_IOMUXC_SD2_DATA3_USDHC2_DATA3		0x1d6
		>;
	};

	/*
	 * Tier C1: KSZ9896 RGMII+MDC/MDIO — same **macros** and **pad values** as Ollie
	 * `docs/reference/dt510-ollie-tool-generated/pin_mux.dts` (BOARD_InitPins ENET1 block, 0x116 / TX_CTL 0x1916).
	 * Omit SAI2_RXC→GPIO4_IO22 — DT510 uses that pad for ZB_INT.
	 */
	pinctrl_fec1_dt510: fec1dt510grp {
		fsl,pins = <
			MX8MM_IOMUXC_ENET_MDC_ENET1_MDC			0x116
			MX8MM_IOMUXC_ENET_MDIO_ENET1_MDIO		0x116
			MX8MM_IOMUXC_ENET_RD0_ENET1_RGMII_RD0		0x116
			MX8MM_IOMUXC_ENET_RD1_ENET1_RGMII_RD1		0x116
			MX8MM_IOMUXC_ENET_RD2_ENET1_RGMII_RD2		0x116
			MX8MM_IOMUXC_ENET_RD3_ENET1_RGMII_RD3		0x116
			MX8MM_IOMUXC_ENET_RXC_ENET1_RGMII_RXC		0x116
			MX8MM_IOMUXC_ENET_RX_CTL_ENET1_RGMII_RX_CTL	0x116
			MX8MM_IOMUXC_ENET_TD0_ENET1_RGMII_TD0		0x116
			MX8MM_IOMUXC_ENET_TD1_ENET1_RGMII_TD1		0x116
			MX8MM_IOMUXC_ENET_TD2_ENET1_RGMII_TD2		0x116
			MX8MM_IOMUXC_ENET_TD3_ENET1_RGMII_TD3		0x116
			MX8MM_IOMUXC_ENET_TXC_ENET1_RGMII_TXC		0x116
			MX8MM_IOMUXC_ENET_TX_CTL_ENET1_RGMII_TX_CTL	0x1916
		>;
	};

	/*
	 * KSZ9896 / ENET sideband (SAI1 balls as GPIO) — Ollie `pin_mux.dts` uses 0x116 on each.
	 * Nets at switch may be # (active low); SoC GPIO hogs use `GPIO_ACTIVE_HIGH` where RST bench
	 * showed stacked inversion vs naive `ACTIVE_LOW` — match PME/INTR/RST (see gpio4 nodes).
	 * SAI1_RXD2  → GPIO4_IO4: ENET_PME#  — input (WoL)
	 * SAI1_RXFS  → GPIO4_IO0: ENET_INTR# — input; if SSOT is SoC *output* only, hog `output-high;`
	 * SAI1_RXC   → GPIO4_IO1: ENET_RST#  — on wire: nRESET active low; pin high = run (see `ksz9896_rst`)
	 * Not in `pinctrl_sai1_tas6424` (TAS uses 5-line SAI1 only). See `docs/DT510-ETHERNET-KSZ9896.md`.
	 */
	pinctrl_ksz9896_sideband: ksz9896sidebandgrp {
		fsl,pins = <
			MX8MM_IOMUXC_SAI1_RXFS_GPIO4_IO0	0x116
			MX8MM_IOMUXC_SAI1_RXC_GPIO4_IO1	0x116
			MX8MM_IOMUXC_SAI1_RXD2_GPIO4_IO4	0x116
		>;
	};
};

&uart1 { /* BT */
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_uart1>;
	assigned-clocks = <&clk IMX8MM_CLK_UART1>;
	assigned-clock-parents = <&clk IMX8MM_SYS_PLL1_80M>;
	fsl,uart-has-rtscts;
	status = "okay";

	bluetooth {
		compatible = "nxp,88w8997-bt";
		fw-init-baudrate = <3000000>;
	};
};

&uart3 {
	status = "disabled";
};

&uart4 {
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_uart4>;
	status = "okay";  /* Safe to enable - RDC assignment handled by U-Boot before kernel boot */

	// UART4 RDC assignment is now handled by U-Boot bootcmd before kernel starts
	// This prevents the synchronous external abort during early boot
	fsl,rdc-domain = <0>;  // Assign to A53 domain
};

&gpio2 {
	wl-wake-dev-hog {
		gpio-hog;
		gpios = <6 GPIO_ACTIVE_HIGH>;
		output-high;
		line-name = "wl-wake-dev";
	};
	bt-wake-dev-hog {
		gpio-hog;
		gpios = <7 GPIO_ACTIVE_HIGH>;
		output-high;
		line-name = "bt-wake-dev";
	};
	// zb-reset-hog {
	//	gpio-hog;
	//	gpios = <11 GPIO_ACTIVE_LOW>;
	//	output-low;
	//	line-name = "zb-reset";
	// };
};

&gpio3 {
	lte-power-down-hog {
		gpio-hog;
		gpios = <1 GPIO_ACTIVE_HIGH>;
		output-low;
		line-name = "lte-power-down";
	};

	wlan-power-down-hog {
		gpio-hog;
		gpios = <7 GPIO_ACTIVE_LOW>;
		output-low;
		line-name = "wlan-power-down#";
	};
	bt-wake-host-hog {
		gpio-hog;
		gpios = <8 GPIO_ACTIVE_HIGH>;
		input;
		line-name = "bt-wake-host";
	};
	bt-reset-hog {
		gpio-hog;
		gpios = <9 GPIO_ACTIVE_LOW>;
		output-low;
		line-name = "bt-reset";
	};
};

&gpio4 {
	/*
	 * KSZ sideband pad mux: applied from `&fec1` pinctrl-0 (with RGMII), not here — i.MX GPIO
	 * controllers are poor owners of a full IOMUXC group; a gpio4 pinctrl-0 can break the bank
	 * or clash with the SoC dtsi. See pinctrl_ksz9896_sideband + &fec1.
	 */
	status = "okay";

	/* Same `GPIO_ACTIVE_*` convention as `ksz9896_rst` (sideband inversion). */
	ksz9896_pme {
		gpio-hog;
		gpios = <4 GPIO_ACTIVE_HIGH>;
		input;
		line-name = "ksz9896-ent-pme";
	};

	/*
	 * INTR: claimed by `ksz9896_sw` (`interrupt-parent` / `interrupts`), not a hog — GPIO4_IO0.
	 * RST: released by `microchip,ksz9896` DSA node (`reset-gpios`). PME hog remains until needed by driver.
	 */

	/* ZB on GPIO4_IO22: pinctrl `pinctrl_zigbee` + unhog here if needed. */
};

/* CODEC_SD# (GPIO5_IO4): Sentai gpio-hog removed — tas2563@4C reset-gpios owns the line (DT510 SSOT, plan §4). */

/*
 * C1 — RGMII to KSZ9896 CPU port: FEC MAC↔switch via DSA (`microchip,ksz9896` on I2C).
 * Integrated PHYs: switch-internal `mdio { }` + `phy-handle` on user ports (Microchip EVB pattern).
 * KSZ sideband: `pinctrl_ksz9896_sideband`; see `docs/DT510-ETHERNET-KSZ9896.md`.
 */
&fec1 {
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_fec1_dt510 &pinctrl_ksz9896_sideband>;
	phy-mode = "rgmii-txid";
	status = "okay";
	/delete-property/ phy-handle;
	/delete-property/ fsl,magic-packet;

	fixed-link {
		speed = <1000>;
		full-duplex;
		pause;
	};
};

/*
 * Tier B2 — imx8mm-evk.dtsi (via imx8mm-evkb.dts) inherits peripherals that clash with DT510:
 * - ir_recv: GPIO1_IO13 (TAS6424 AMP_FAULT#/WARN# mux on same pins).
 * - reg_pcie0: GPIO1_IO5 (&pcie0 is disabled on DT510).
 * - backlight: headless / no panel; disable pwm-backlight node.
 * Incremental step 2 (E1 baseline): EVK nodes off only; pinctrl unchanged.
 */
&ir_recv {
	status = "disabled";
};

&reg_pcie0 {
	status = "disabled";
};

&backlight {
	status = "disabled";
};

/* Tier B3 — CP2108 quad-UART: USB-enumerated; add reset GPIO here only when SSOT names a pin. */

/* Tier B4 — SE050 @ I2C4 0x48: OpTEE (se05x) — see docs/DT510-SE050.md; no Linux &i2c4 child required. */
/* &i2c1: PMIC-only on DT510 (PCA9450 from imx8mm-evkb); no other I²C1 clients in this DTS. */

&i2c2 {
	/*
	 * imx8mm-evk.dtsi defines tcpc@50 (PTN5110 TCPC). DT510 does not populate it;
	 * remove the inherited node so I2C2 @ 0x50 is free for TAC5301 (Tier C2) per SSOT.
	 */
	/delete-node/ tcpc@50;

	/*
	 * TI TAC5301-Q1 @ 0x50 — I2C2, 7-bit 0x50 (TI default). Frees EVK PTN5110 @ 0x50 (deleted above).
	 * GPIO4_IO14: configurable codec GPIO (Ollie SSOT); bound as reset until IRQ confirmed.
	 */
	tac5301: tac5301@50 {
		compatible = "ti,tac5301";
		reg = <0x50>;
		#sound-dai-cells = <0>;
		pinctrl-names = "default";
		pinctrl-0 = <&pinctrl_tac5301_gpio>;
		reset-gpios = <&gpio4 14 GPIO_ACTIVE_LOW>;
		status = "okay";
	};

	// Audio Amp with Dual Hardware Support
	tas2563: tas2563@4C {
		#sound-dai-cells = <0>;
		compatible = "ti,tas2563";
		reg = <0x4C>;
		ti,channels = <1>; /* channel number */
		reset-gpios = <&gpio5 4 GPIO_ACTIVE_LOW>;   /* Enable reset control - active low */
		interrupt-parent = <&gpio5>;
		interrupts = <5 IRQ_TYPE_LEVEL_LOW>;

		// Basic I2S Configuration for TAS2562 driver
		ti,asi-format = <0>; /* 0=I2S format */
		ti,left-slot = <0>; /* Left audio channel */
		ti,right-slot = <1>; /* Right audio channel */

		// TAS2562 driver does not support PDM microphones
		// Use MICFIL for microphone input instead

		status = "okay";
	};

	/*
	 * TAS6424E-Q1 @ 0x6A — class-D on SAI1 (Tier C2).
	 * SSOT (Google Doc): GPIO1_IO10 = AMP_STBY#, GPIO1_IO11 = AMP_MUTE# (outputs, active-low);
	 * GPIO1_IO12 = AMP_FAULT#, GPIO1_IO13 = AMP_WARN# (inputs, active-low) — not wired to codec driver.
	 */
	tas6424: tas6424@6a {
		compatible = "ti,tas6424";
		reg = <0x6a>;
		#sound-dai-cells = <0>;
		pinctrl-names = "default";
		pinctrl-0 = <&pinctrl_tas6424_gpio>;
		dvdd-supply = <&vddext>;
		vbat-supply = <&tas6424_hi_rail>;
		pvdd-supply = <&tas6424_hi_rail>;
		standby-gpios = <&gpio1 10 GPIO_ACTIVE_LOW>;
		mute-gpios = <&gpio1 11 GPIO_ACTIVE_LOW>;
		status = "okay";
	};

	/*
	 * KSZ9896 — I2C management + DSA (see `Documentation/devicetree/bindings/net/dsa/microchip,ksz.yaml`).
	 * PLACEHOLDER until EE confirms: SoC I2C controller + ball mux + KSZ strap 7-bit address (often 0x5f).
	 * If routed to &i2c1 or &i2c3 instead, move this node and set reg = <addr> from straps.
	 */
	ksz9896_sw: switch@5f {
		compatible = "microchip,ksz9896";
		reg = <0x5f>;
		reset-gpios = <&gpio4 1 GPIO_ACTIVE_LOW>;
		interrupt-parent = <&gpio4>;
		/* EE: change to EDGE_FALLING / LEVEL_HIGH if INT# polarity differs from schematic */
		interrupts = <0 IRQ_TYPE_LEVEL_LOW>;

		ethernet-ports {
			#address-cells = <1>;
			#size-cells = <0>;

			port@0 {
				reg = <0>;
				label = "lan1";
				phy-handle = <&swphy0>;
			};

			port@1 {
				reg = <1>;
				label = "lan2";
				phy-handle = <&swphy1>;
			};

			port@2 {
				reg = <2>;
				label = "lan3";
				phy-handle = <&swphy2>;
			};

			port@3 {
				reg = <3>;
				label = "lan4";
				phy-handle = <&swphy3>;
			};

			port@5 {
				reg = <5>;
				label = "cpu";
				ethernet = <&fec1>;
				phy-mode = "rgmii-txid";
				tx-internal-delay-ps = <2000>;

				fixed-link {
					speed = <1000>;
					full-duplex;
					pause;
				};
			};
		};

		mdio {
			#address-cells = <1>;
			#size-cells = <0>;

			swphy0: ethernet-phy@0 {
				reg = <0>;
				eee-broken-100tx;
				eee-broken-1000t;
			};

			swphy1: ethernet-phy@1 {
				reg = <1>;
				eee-broken-100tx;
				eee-broken-1000t;
			};

			swphy2: ethernet-phy@2 {
				reg = <2>;
				eee-broken-100tx;
				eee-broken-1000t;
			};

			swphy3: ethernet-phy@3 {
				reg = <3>;
				eee-broken-100tx;
				eee-broken-1000t;
			};
		};
	};
};

&i2c3 {
	stts22h: stts22h@3F {
		compatible = "st,stts22h";
		reg = <0x3f>;
		// sampling-rate = <STTS22H_100Hz>;
		status = "okay";
		interrupt-parent = <&gpio4>;
		interrupts = <8 IRQ_TYPE_LEVEL_HIGH>;
	};

	ov5640_mipi: ov5640_mipi@3c {
		status = "disabled";
	};

	pca6416: gpio@20 {
		status = "disabled";
	};

	ak4458_1: ak4458@10 {
		status = "disabled";
	};

	ak4458_2: ak4458@12 {
		status = "disabled";
	};

	ak5558: ak5558@13 {
		status = "disabled";
	};

	ak4497: ak4497@11 {
		status = "disabled";
	};

	/* Tier B1: BQ25792 @ 0x6B on I2C3 — CHGR_INT# → SAI1_RXD7 / GPIO4_IO9 (active-low, B1 SSOT). */
	bq25792: bq25792@6b {
		compatible = "ti,bq25792";
		reg = <0x6b>;
		monitored-battery = <&battery_dt510>;
		interrupt-parent = <&gpio4>;
		interrupts = <9 IRQ_TYPE_LEVEL_LOW>;
		status = "okay";
	};

	/* SSOT placeholder (disabled): enable Tier C3 after probe + pinctrl validation */

	lt9611: lt9611@39 {
		compatible = "lontium,lt9611";
		reg = <0x39>;
		status = "disabled";
	};

};

&sai1 {
	/* TAS6424: I2S to class-D (5-line pinmux in pinctrl_sai1_tas6424). SAI1_RXD7 is CHGR_INT# on I2C3, not SAI. */
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_sai1_tas6424>;
	assigned-clocks = <&clk IMX8MM_CLK_SAI1_ROOT>;
	assigned-clock-parents = <&clk IMX8MM_AUDIO_PLL1_OUT>;
	assigned-clock-rates = <12288000>;
	fsl,sai-mclk-direction-output;
	#sound-dai-cells = <0>;
	status = "okay";
};

/* PDM: prior mux used SAI1 pins for MICFIL — conflicts with TAS6424 SSOT; leave off until a product variant needs PDM on another block */
&micfil {
	status = "disabled";
};

// Enhanced SAI3 configuration for bidirectional audio (Profile 8 echo reference)
&sai3 {
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_sai3>;
	assigned-clocks = <&clk IMX8MM_CLK_SAI3>;
	assigned-clock-parents = <&clk IMX8MM_AUDIO_PLL1_OUT>;
	assigned-clock-rates = <12288000>;
	fsl,sai-mclk-direction-output;
	fsl,sai-synchronous-rx;  /* RX uses TX clocks for synchronized operation */
	#sound-dai-cells = <0>;
	status = "okay";
};

/* TAC5301-Q1 — I2S on SAI6 (Ollie SSOT); CPU BCLK/FS master, codec slave. */
&sai6 {
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_sai6_tac5301>;
	assigned-clocks = <&clk IMX8MM_CLK_SAI6_ROOT>;
	assigned-clock-parents = <&clk IMX8MM_AUDIO_PLL1_OUT>;
	assigned-clock-rates = <12288000>;
	fsl,sai-mclk-direction-output;
	fsl,sai-synchronous-rx;
	#sound-dai-cells = <0>;
	status = "okay";
};

&mipi_dsi {
	status = "disabled";
};

&spdif1 {
	status = "disabled";
};

&pcie0 {
	status = "disabled";
};

// 802.15.4
&ecspi1 {
	#address-cells = <1>;
	#size-cells = <0>;
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_ecspi1>, <&pinctrl_zigbee>;
	cs-gpios = <&gpio5 9 GPIO_ACTIVE_LOW>;
	fsl,spi-num-chipselects = <1>;
	// Force PIO mode by removing DMA properties entirely
	/delete-property/ dmas;
	/delete-property/ dma-names;
	// Increase timeout for SPI transfers
	fsl,spi-rdy-drctl = <0>;
	// Re-enable burst mode - zb_mux expects 16-byte offset
	// fsl,spi-disable-burst;
	status = "okay";

	spidev1: spi@0 {
		compatible = "rohm,dh2228fv";
		spi-max-frequency = <10000000>; // 10MHz - maximum radio spec limit
		spi-mode = <0>;                 // SPI Mode 0 (CPOL=0, CPHA=0)
		reg = <0>;
	};
};

// ECSPI2: reserved for CAN (MCP2518xx) per DT510 — XM125 lives on Sentai DTS only
&ecspi2 {
	status = "disabled";  /* Enable when CAN bring-up is ready */
	/delete-property/ pinctrl-names;
	/delete-property/ pinctrl-0;
};

/* USB OTG1: peripheral mode for USB gadget / lab dual-UAC2 (see DT510-USB-DUAL-AUDIO.md).
 * No STUSB4500 USB-PD controller on DT510 — not USB-C powered; no TCPC. Sentai-only PD path.
 */
&usbotg1 {
	dr_mode = "peripheral";
	status = "okay";
	/* imx8mm-evk.dtsi links usb1_drd_sw to typec1_dr_sw on &ptn5110 (tcpc@50). We delete tcpc@50;
	 * drop the role-switch graph so DTC does not reference a missing typec1_dr_sw phandle. */
	/delete-property/ usb-role-switch;
	/delete-node/ port;
};

// WiFi SDIO Interface - IW612 module with power management
&usdhc2 {
	pinctrl-names = "default", "state_100mhz", "state_200mhz";
	pinctrl-0 = <&pinctrl_usdhc2>;
	pinctrl-1 = <&pinctrl_usdhc2_100mhz>;
	pinctrl-2 = <&pinctrl_usdhc2_200mhz>;
	bus-width = <4>;
	keep-power-in-suspend;
	non-removable;
	wakeup-source;
	max-frequency = <100000000>;
	fsl,sdio-async-interrupt-enabled;
	pm-ignore-notify;
	cap-power-off-card;
	status = "okay";

	wifi_wake_host {
		compatible = "nxp,wifi-wake-host";
		interrupt-parent = <&gpio2>;
		interrupts = <6 IRQ_TYPE_LEVEL_LOW>;  /* WL_WAKE_DEV GPIO */
		interrupt-names = "host-wake";
		wakeup-source;
	};
};

// Cellular modem
&usbotg2 {
	dr_mode = "host";
	status = "okay";
};
