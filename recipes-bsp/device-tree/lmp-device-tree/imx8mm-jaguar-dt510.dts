/*
 * Copyright 2020 NXP
 */
/*
 * i.MX8MM Jaguar DT510 — board DTS (Tier A2). Kernel recipe symlinks Tier A1 to this file.
 *
 * Hardware SSOT: DT510 pinout/spec (Google Doc). Pin mux cross-check:
 * docs/reference/dt510-ollie-tool-generated/. Plan: docs/DT510-BSP-PROJECT-PLAN.md
 */

#include "freescale/imx8mm-evkb.dts"
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>
#include <dt-bindings/interrupt-controller/irq.h>
#include <dt-bindings/clock/imx8mm-clock.h>

/*
 * Base: imx8mm-evkb.dts — PCA9450 on i2c1 @0x25 (not BD71847). Extra fragments replay imx8mm-evk.dts
 * bits missing from the evkb-only path (DDR OPP, USDHC). No FlexSPI on DT510.
 */

/ {
	model = "i.MX8MM Jaguar DT510 board";
	compatible = "fsl,imx8mm-jaguar-dt510", "fsl,imx8mm-evkb", "fsl,imx8mm-evk", "fsl,imx8mm";

	/* Fixed rails */
	/* TAS6424 DVDD 3.3 V — confirm nominal vs schematic (SSOT). */
	vddext: regulator-vddext {
		compatible = "regulator-fixed";
		regulator-name = "VDDEXT_3V3";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
	};

	/*
	 * TAS6424 VBAT + PVDD (driver wants separate supplies; one rail for both).
	 * 12 V nominal — confirm nets/BOM. Always-on rails: regulator-always-on is fine.
	 */
	tas6424_hi_rail: regulator-tas6424-hi {
		compatible = "regulator-fixed";
		regulator-name = "TAS6424_VBAT_PVDD";
		regulator-min-microvolt = <12000000>;
		regulator-max-microvolt = <12000000>;
		regulator-always-on;
	};

	/* TAS6424 class-D: CPU (SAI1) bit/frame clock master, codec slave */
	sound-tas6424 {
		compatible = "simple-audio-card";
		simple-audio-card,name = "tas6424-classd";
		simple-audio-card,format = "i2s";
		simple-audio-card,frame-master = <&tas6424_cpu_dai>;
		simple-audio-card,bitclock-master = <&tas6424_cpu_dai>;
		simple-audio-card,widgets =
			"Speaker", "Speaker";
		simple-audio-card,routing =
			"Speaker", "OUT";

		tas6424_cpu_dai: simple-audio-card,cpu {
			sound-dai = <&sai1>;
		};

		simple-audio-card,codec {
			sound-dai = <&tas6424>;
			clocks = <&clk IMX8MM_CLK_SAI1_ROOT>;
		};
	};

	sound-tas2563 {
		compatible = "simple-audio-card";
		simple-audio-card,name = "tas2563-audio";
		simple-audio-card,format = "i2s";
		simple-audio-card,frame-master = <&cpudai2>;
		simple-audio-card,bitclock-master = <&cpudai2>;

		/* tas2563: simple-card routing (no DMIC widgets) */
		simple-audio-card,widgets =
			"Speaker", "Speaker";
		simple-audio-card,routing =
			"Speaker", "OUT";

		cpudai2: simple-audio-card,cpu {
			sound-dai = <&sai3>;
			dai-tdm-slot-num = <4>;  /* Profile 8 */
			dai-tdm-slot-width = <32>;
		};

		simple-audio-card,codec {
			sound-dai = <&tas2563>;
			clocks = <&clk IMX8MM_CLK_SAI3_ROOT>;
		};
	};

	/* TAC5301-Q1 @ i2c2 0x50 — mono codec; SAI6 mux per pin_mux.dts. Needs ti,tac5301 / TAC5x1x in kernel */
	sound-tac5301 {
		compatible = "simple-audio-card";
		simple-audio-card,name = "tac5301-analog";
		simple-audio-card,format = "i2s";
		simple-audio-card,frame-master = <&tac5301_cpu_dai>;
		simple-audio-card,bitclock-master = <&tac5301_cpu_dai>;
		simple-audio-card,widgets =
			"Speaker", "Speaker";
		simple-audio-card,routing =
			"Speaker", "OUT";

		tac5301_cpu_dai: simple-audio-card,cpu {
			sound-dai = <&sai6>;
		};

		simple-audio-card,codec {
			sound-dai = <&tac5301>;
			clocks = <&clk IMX8MM_CLK_SAI6_ROOT>;
		};
	};

	/* EVK MICFIL audio card — disabled (SAI1 used for TAS6424) */
	sound-micfil {
		compatible = "fsl,imx-audio-card";
		model = "micfil-audio";
		status = "disabled";
		pri-dai-link {
			link-name = "micfil hifi";
			format = "i2s";
			cpu {
				sound-dai = <&micfil>;
			};
		};
	};

	sound-wm8524 {
		status = "disabled";
	};

	sound-ak4458 {
		status = "disabled";
	};

	sound-spdif {
		status = "disabled";
	};

	sound-bt-sco {
		status = "disabled";
	};

	/* Cortex-M4 not used */
	imx8mm-cm4 {
		compatible = "fsl,imx8mm-cm4";
		status = "disabled";
	};

	/* RDC: UART4 PDAP for A53 (domain 0) — must match U-Boot setup before &uart4 probes */
	rdc: rdc@303d0000 {
		compatible = "fsl,imx8mm-rdc";
		reg = <0x0 0x303d0000 0x0 0x10000>;
		status = "okay";

		fsl,rdc-config = <
			0x44  0x3  /* UART4 PDAP — domain 0 R/W */
		>;
	};

	sw-keys {
		compatible = "gpio-keys";
		status = "okay";

		sw1: key-act {
			label = "Key Act";
			linux,code = <BTN_SELECT>;
			gpios = <&gpio3 6 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
			interrupt-parent = <&gpio3>;
			interrupt = <6 IRQ_TYPE_EDGE_FALLING>;
		};
	};

	/* BQ25792 simple-battery model — tune per pack (1S placeholder) */
	battery_dt510: battery-dt510 {
		compatible = "simple-battery";
		constant-charge-voltage-max-microvolt = <4200000>;
		constant-charge-current-max-microamp = <2000000>;
		charge-term-current-microamp = <160000>;
	};
};

/* DDR OPP table — from imx8mm-evk.dts (not in imx8mm-evkb include path) */
&ddrc {
	operating-points-v2 = <&ddrc_opp_table>;

	ddrc_opp_table: opp-table {
		compatible = "operating-points-v2";

		opp-25000000 {
			opp-hz = /bits/ 64 <25000000>;
		};

		opp-100000000 {
			opp-hz = /bits/ 64 <100000000>;
		};

		opp-750000000 {
			opp-hz = /bits/ 64 <750000000>;
		};
	};
};

&iomuxc {
	pinctrl-names = "default";
	/* Boot hog: WL/BT/LTE rails; BQ25792 CHGR_INT mux in pinctrl_bq25792_chgr_int */
	pinctrl-0 = <&pinctrl_hog>, <&pinctrl_bq25792_chgr_int>;

	pinctrl_hog: hoggrp {
		fsl,pins = <
			MX8MM_IOMUXC_SD1_DATA4_GPIO2_IO6	0x140  // WL_WAKE_DEV
			MX8MM_IOMUXC_SD1_DATA5_GPIO2_IO7	0x140  // BT_WAKE_DEV
			MX8MM_IOMUXC_SD1_DATA6_GPIO2_IO8	0x000  // LTE_RESET
			MX8MM_IOMUXC_NAND_CE0_B_GPIO3_IO1	0x140  // FUL_CARD_POWER_OFF#
			MX8MM_IOMUXC_NAND_DATA01_GPIO3_IO7	0x140  // WIFI_PD#
			MX8MM_IOMUXC_NAND_DATA02_GPIO3_IO8	0x140  // BT_WAKE_HOST
			MX8MM_IOMUXC_NAND_DATA03_GPIO3_IO9	0x140  // BT_RST#
			/* Other SAI1 pads: TAS6424 / SAI6 / BQ charger — see pin_mux.dts */
			MX8MM_IOMUXC_SPDIF_RX_GPIO5_IO4		0x140  /* CODEC_SD# */
		>;
	};

	/* Zigbee (ZBoss): ZB_INT / ZB_RST — dedicated mux, not in hoggrp */
	pinctrl_zigbee: zigbeegrp {
		fsl,pins = <
			MX8MM_IOMUXC_SAI2_RXC_GPIO4_IO22		0x140  // ZB_INT
			MX8MM_IOMUXC_SD1_STROBE_GPIO2_IO11		0x140  // ZB_RST#
		>;
	};

	/* ECSPI1 (802.15.4): 0x140 drive */
	pinctrl_ecspi1: ecspi1grp {
		fsl,pins = <
			MX8MM_IOMUXC_ECSPI1_SS0_GPIO5_IO9		0x140
			MX8MM_IOMUXC_ECSPI1_SCLK_ECSPI1_SCLK		0x140
			MX8MM_IOMUXC_ECSPI1_MISO_ECSPI1_MISO		0x140
			MX8MM_IOMUXC_ECSPI1_MOSI_ECSPI1_MOSI		0x140
		>;
	};

	pinctrl_sai3: sai3grp {
		fsl,pins = <
			MX8MM_IOMUXC_SAI3_TXFS_SAI3_TX_SYNC		0xd6    // Frame sync
			MX8MM_IOMUXC_SAI3_TXC_SAI3_TX_BCLK		0xd6    // Bit clock
			MX8MM_IOMUXC_SAI3_MCLK_SAI3_MCLK		0xd6    // Master clock
			MX8MM_IOMUXC_SAI3_TXD_SAI3_TX_DATA0		0xd6    // Transmit (playback)
			MX8MM_IOMUXC_SAI3_RXD_SAI3_RX_DATA0		0xd6    // Receive (from TAS2563 mics)
			MX8MM_IOMUXC_SPDIF_EXT_CLK_GPIO5_IO5		0xd6    // Audio codec interrupt
		>;
	};

	/*
	 * TAS6424 GPIO1 sideband (standby/mute/fault/warn) — 0x116 per pin_mux.dts.
	 * Keep separate from pinctrl_sai1_tas6424 (I2S data only).
	 */
	pinctrl_tas6424_gpio: tas6424gpiogrp {
		fsl,pins = <
			MX8MM_IOMUXC_GPIO1_IO10_GPIO1_IO10	0x116
			MX8MM_IOMUXC_GPIO1_IO11_GPIO1_IO11	0x116
			MX8MM_IOMUXC_GPIO1_IO12_GPIO1_IO12	0x116
			MX8MM_IOMUXC_GPIO1_IO13_GPIO1_IO13	0x116
		>;
	};

	/* BQ25792 CHGR_INT# → SAI1_RXD7 as GPIO4_IO9 (active-low); not SAI */
	pinctrl_bq25792_chgr_int: bq25792_chgr_int_grp {
		fsl,pins = <
			MX8MM_IOMUXC_SAI1_RXD7_GPIO4_IO9	0x140  /* CHGR_INT# */
		>;
	};

	/* TAS6424 SAI1 I2S (5 lines): 0x116 on MCLK/BCLK/DATA; 0x1916 on frame sync (matches ENET TX_CTL skew) */
	pinctrl_sai1_tas6424: sai1tas6424grp {
		fsl,pins = <
			MX8MM_IOMUXC_SAI1_MCLK_SAI1_MCLK		0x116
			MX8MM_IOMUXC_SAI1_TXFS_SAI1_TX_SYNC		0x1916
			MX8MM_IOMUXC_SAI1_TXC_SAI1_TX_BCLK		0x116
			MX8MM_IOMUXC_SAI1_TXD0_SAI1_TX_DATA0	0x116
			MX8MM_IOMUXC_SAI1_TXD1_SAI1_TX_DATA1	0x116
		>;
	};

	/* TAC5301 ↔ SAI6 — 0x116 per pin_mux.dts */
	pinctrl_sai6_tac5301: sai6_tac5301_grp {
		fsl,pins = <
			MX8MM_IOMUXC_SAI1_RXD6_SAI6_TX_SYNC		0x116
			MX8MM_IOMUXC_SAI1_RXD4_SAI6_TX_BCLK		0x116
			MX8MM_IOMUXC_SAI1_RXD5_SAI6_TX_DATA0		0x116
			MX8MM_IOMUXC_SAI1_TXD5_SAI6_RX_DATA0		0x116
		>;
	};

	/* TAC5301 codec GPIO / reset — SAI1_TXD2 → GPIO4_IO14 */
	pinctrl_tac5301_gpio: tac5301_gpio_grp {
		fsl,pins = <
			MX8MM_IOMUXC_SAI1_TXD2_GPIO4_IO14		0x116
		>;
	};

	pinctrl_uart1: uart1grp {
		fsl,pins = <
			MX8MM_IOMUXC_UART1_RXD_UART1_DCE_RX		0x140
			MX8MM_IOMUXC_UART1_TXD_UART1_DCE_TX		0x140
			MX8MM_IOMUXC_UART3_TXD_UART1_DCE_RTS_B		0x140
			MX8MM_IOMUXC_UART3_RXD_UART1_DCE_CTS_B		0x140
		>;
	};

	pinctrl_uart4: uart4grp {
		fsl,pins = <
			MX8MM_IOMUXC_UART4_RXD_UART4_DCE_RX		0x140
			MX8MM_IOMUXC_UART4_TXD_UART4_DCE_TX		0x140
		>;
	};

	pinctrl_usdhc2: usdhc2grp {
		fsl,pins = <
			MX8MM_IOMUXC_SD2_CLK_USDHC2_CLK		0x190
			MX8MM_IOMUXC_SD2_CMD_USDHC2_CMD		0x1d0
			MX8MM_IOMUXC_SD2_DATA0_USDHC2_DATA0		0x1d0
			MX8MM_IOMUXC_SD2_DATA1_USDHC2_DATA1		0x1d0
			MX8MM_IOMUXC_SD2_DATA2_USDHC2_DATA2		0x1d0
			MX8MM_IOMUXC_SD2_DATA3_USDHC2_DATA3		0x1d0
		>;
	};

	pinctrl_usdhc2_100mhz: usdhc2-100mhzgrp {
		fsl,pins = <
			MX8MM_IOMUXC_SD2_CLK_USDHC2_CLK		0x194
			MX8MM_IOMUXC_SD2_CMD_USDHC2_CMD		0x1d4
			MX8MM_IOMUXC_SD2_DATA0_USDHC2_DATA0		0x1d4
			MX8MM_IOMUXC_SD2_DATA1_USDHC2_DATA1		0x1d4
			MX8MM_IOMUXC_SD2_DATA2_USDHC2_DATA2		0x1d4
			MX8MM_IOMUXC_SD2_DATA3_USDHC2_DATA3		0x1d4
		>;
	};

	pinctrl_usdhc2_200mhz: usdhc2-200mhzgrp {
		fsl,pins = <
			MX8MM_IOMUXC_SD2_CLK_USDHC2_CLK		0x196
			MX8MM_IOMUXC_SD2_CMD_USDHC2_CMD		0x1d6
			MX8MM_IOMUXC_SD2_DATA0_USDHC2_DATA0		0x1d6
			MX8MM_IOMUXC_SD2_DATA1_USDHC2_DATA1		0x1d6
			MX8MM_IOMUXC_SD2_DATA2_USDHC2_DATA2		0x1d6
			MX8MM_IOMUXC_SD2_DATA3_USDHC2_DATA3		0x1d6
		>;
	};

	/* USDHC3 eMMC 8-bit (EVK NAND pinmux) */
	pinctrl_usdhc3: usdhc3grp {
		fsl,pins = <
			MX8MM_IOMUXC_NAND_WE_B_USDHC3_CLK               0x190
			MX8MM_IOMUXC_NAND_WP_B_USDHC3_CMD               0x1d0
			MX8MM_IOMUXC_NAND_DATA04_USDHC3_DATA0           0x1d0
			MX8MM_IOMUXC_NAND_DATA05_USDHC3_DATA1           0x1d0
			MX8MM_IOMUXC_NAND_DATA06_USDHC3_DATA2           0x1d0
			MX8MM_IOMUXC_NAND_DATA07_USDHC3_DATA3           0x1d0
			MX8MM_IOMUXC_NAND_RE_B_USDHC3_DATA4             0x1d0
			MX8MM_IOMUXC_NAND_CE2_B_USDHC3_DATA5            0x1d0
			MX8MM_IOMUXC_NAND_CE3_B_USDHC3_DATA6            0x1d0
			MX8MM_IOMUXC_NAND_CLE_USDHC3_DATA7              0x1d0
			MX8MM_IOMUXC_NAND_CE1_B_USDHC3_STROBE           0x190
		>;
	};

	pinctrl_usdhc3_100mhz: usdhc3-100mhzgrp {
		fsl,pins = <
			MX8MM_IOMUXC_NAND_WE_B_USDHC3_CLK               0x194
			MX8MM_IOMUXC_NAND_WP_B_USDHC3_CMD               0x1d4
			MX8MM_IOMUXC_NAND_DATA04_USDHC3_DATA0           0x1d4
			MX8MM_IOMUXC_NAND_DATA05_USDHC3_DATA1           0x1d4
			MX8MM_IOMUXC_NAND_DATA06_USDHC3_DATA2           0x1d4
			MX8MM_IOMUXC_NAND_DATA07_USDHC3_DATA3           0x1d4
			MX8MM_IOMUXC_NAND_RE_B_USDHC3_DATA4             0x1d4
			MX8MM_IOMUXC_NAND_CE2_B_USDHC3_DATA5            0x1d4
			MX8MM_IOMUXC_NAND_CE3_B_USDHC3_DATA6            0x1d4
			MX8MM_IOMUXC_NAND_CLE_USDHC3_DATA7              0x1d4
			MX8MM_IOMUXC_NAND_CE1_B_USDHC3_STROBE           0x194
		>;
	};

	pinctrl_usdhc3_200mhz: usdhc3-200mhzgrp {
		fsl,pins = <
			MX8MM_IOMUXC_NAND_WE_B_USDHC3_CLK               0x196
			MX8MM_IOMUXC_NAND_WP_B_USDHC3_CMD               0x1d6
			MX8MM_IOMUXC_NAND_DATA04_USDHC3_DATA0           0x1d6
			MX8MM_IOMUXC_NAND_DATA05_USDHC3_DATA1           0x1d6
			MX8MM_IOMUXC_NAND_DATA06_USDHC3_DATA2           0x1d6
			MX8MM_IOMUXC_NAND_DATA07_USDHC3_DATA3           0x1d6
			MX8MM_IOMUXC_NAND_RE_B_USDHC3_DATA4             0x1d6
			MX8MM_IOMUXC_NAND_CE2_B_USDHC3_DATA5            0x1d6
			MX8MM_IOMUXC_NAND_CE3_B_USDHC3_DATA6            0x1d6
			MX8MM_IOMUXC_NAND_CLE_USDHC3_DATA7              0x1d6
			MX8MM_IOMUXC_NAND_CE1_B_USDHC3_STROBE           0x196
		>;
	};

	/* KSZ9896 RGMII — ENET1 pins per pin_mux.dts; SAI2_RXC left for ZB_INT (not in this group) */
	pinctrl_fec1_dt510: fec1dt510grp {
		fsl,pins = <
			MX8MM_IOMUXC_ENET_MDC_ENET1_MDC			0x116
			MX8MM_IOMUXC_ENET_MDIO_ENET1_MDIO		0x116
			MX8MM_IOMUXC_ENET_RD0_ENET1_RGMII_RD0		0x116
			MX8MM_IOMUXC_ENET_RD1_ENET1_RGMII_RD1		0x116
			MX8MM_IOMUXC_ENET_RD2_ENET1_RGMII_RD2		0x116
			MX8MM_IOMUXC_ENET_RD3_ENET1_RGMII_RD3		0x116
			MX8MM_IOMUXC_ENET_RXC_ENET1_RGMII_RXC		0x116
			MX8MM_IOMUXC_ENET_RX_CTL_ENET1_RGMII_RX_CTL	0x116
			MX8MM_IOMUXC_ENET_TD0_ENET1_RGMII_TD0		0x116
			MX8MM_IOMUXC_ENET_TD1_ENET1_RGMII_TD1		0x116
			MX8MM_IOMUXC_ENET_TD2_ENET1_RGMII_TD2		0x116
			MX8MM_IOMUXC_ENET_TD3_ENET1_RGMII_TD3		0x116
			MX8MM_IOMUXC_ENET_TXC_ENET1_RGMII_TXC		0x116
			MX8MM_IOMUXC_ENET_TX_CTL_ENET1_RGMII_TX_CTL	0x1916
		>;
	};

	/*
	 * KSZ sideband on SAI1 balls → GPIO4: INTR, RST, PME (polarity vs switch — see DT510-ETHERNET-KSZ9896.md).
	 * gpio-hog ACTIVE_* must match hardware; see also &ksz9896_sw reset-gpios.
	 */
	pinctrl_ksz9896_sideband: ksz9896sidebandgrp {
		fsl,pins = <
			MX8MM_IOMUXC_SAI1_RXFS_GPIO4_IO0	0x116
			MX8MM_IOMUXC_SAI1_RXC_GPIO4_IO1	0x116
			MX8MM_IOMUXC_SAI1_RXD2_GPIO4_IO4	0x116
		>;
	};
};

/* UART1 — Bluetooth HCI */
&uart1 {
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_uart1>;
	assigned-clocks = <&clk IMX8MM_CLK_UART1>;
	assigned-clock-parents = <&clk IMX8MM_SYS_PLL1_80M>;
	fsl,uart-has-rtscts;
	status = "okay";

	bluetooth {
		compatible = "nxp,88w8997-bt";
		fw-init-baudrate = <3000000>;
	};
};

&uart3 {
	status = "disabled";
};

&uart4 {
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_uart4>;
	status = "okay";

	/* Domain 0 (A53); RDC programmed from &rdc / U-Boot before probe */
	fsl,rdc-domain = <0>;
};

&gpio2 {
	wl-wake-dev-hog {
		gpio-hog;
		gpios = <6 GPIO_ACTIVE_HIGH>;
		output-high;
		line-name = "wl-wake-dev";
	};
	bt-wake-dev-hog {
		gpio-hog;
		gpios = <7 GPIO_ACTIVE_HIGH>;
		output-high;
		line-name = "bt-wake-dev";
	};
	/* ZB_RST# routed via pinctrl_zigbee — not hogged here */
};

&gpio3 {
	lte-power-down-hog {
		gpio-hog;
		gpios = <1 GPIO_ACTIVE_HIGH>;
		output-low;
		line-name = "lte-power-down";
	};

	wlan-power-down-hog {
		gpio-hog;
		gpios = <7 GPIO_ACTIVE_LOW>;
		output-low;
		line-name = "wlan-power-down#";
	};
	bt-wake-host-hog {
		gpio-hog;
		gpios = <8 GPIO_ACTIVE_HIGH>;
		input;
		line-name = "bt-wake-host";
	};
	bt-reset-hog {
		gpio-hog;
		gpios = <9 GPIO_ACTIVE_LOW>;
		output-low;
		line-name = "bt-reset";
	};
};

&gpio4 {
	/*
	 * KSZ/Switch sideband mux lives on &fec1 (pinctrl_ksz9896_sideband), not on gpio4 — avoids
	 * splitting one IOMUX bank across controllers.
	 */
	status = "okay";

	ksz9896_pme {
		gpio-hog;
		gpios = <4 GPIO_ACTIVE_HIGH>;
		input;
		line-name = "ksz9896-ent-pme";
	};
};

/* GPIO5_IO4 CODEC_SD# — tas2563@4c reset-gpios (no Sentai-style hog on DT510) */

/* FEC ↔ KSZ9896 CPU port (DSA on i2c2). Details: docs/DT510-ETHERNET-KSZ9896.md */
&fec1 {
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_fec1_dt510 &pinctrl_ksz9896_sideband>;
	phy-mode = "rgmii-txid";
	status = "okay";
	/delete-property/ phy-handle;
	/delete-property/ fsl,magic-packet;

	fixed-link {
		speed = <1000>;
		full-duplex;
		pause;
	};
};

/*
 * EVK inherited nodes disabled on DT510:
 * ir_recv (GPIO1_IO13 — TAS6424 fault/warn), reg_pcie0 / pcie (GPIO1_IO5), backlight (no panel).
 */
&ir_recv {
	status = "disabled";
};

&reg_pcie0 {
	status = "disabled";
};

&backlight {
	status = "disabled";
};

/* CP2108 quad-UART: USB device — add GPIO reset here if SSOT assigns one */

/* SE050 @ i2c4 0x48: OpTEE only — docs/DT510-SE050.md */

/* i2c1: PCA9450 PMIC only (imx8mm-evkb) */

&i2c2 {
	/* Drop EVK tcpc@50 / PTN5110 — DT510 uses 0x50 for TAC5301 */
	/delete-node/ tcpc@50;

	/* TAC5301-Q1 @ 0x50; GPIO4_IO14 = reset (ti,tac5301) */
	tac5301: tac5301@50 {
		compatible = "ti,tac5301";
		reg = <0x50>;
		#sound-dai-cells = <0>;
		pinctrl-names = "default";
		pinctrl-0 = <&pinctrl_tac5301_gpio>;
		reset-gpios = <&gpio4 14 GPIO_ACTIVE_LOW>;
		status = "okay";
	};

	/* TAS2563 smart amp */
	tas2563: tas2563@4c {
		#sound-dai-cells = <0>;
		compatible = "ti,tas2563";
		reg = <0x4c>;
		ti,channels = <1>;
		reset-gpios = <&gpio5 4 GPIO_ACTIVE_LOW>;
		interrupt-parent = <&gpio5>;
		interrupts = <5 IRQ_TYPE_LEVEL_LOW>;

		ti,asi-format = <0>; /* I2S */
		ti,left-slot = <0>;
		ti,right-slot = <1>;

		status = "okay";
	};

	/* TAS6424 class-D @ 0x6a — GPIO sideband in pinctrl_tas6424_gpio */
	tas6424: tas6424@6a {
		compatible = "ti,tas6424";
		reg = <0x6a>;
		#sound-dai-cells = <0>;
		pinctrl-names = "default";
		pinctrl-0 = <&pinctrl_tas6424_gpio>;
		dvdd-supply = <&vddext>;
		vbat-supply = <&tas6424_hi_rail>;
		pvdd-supply = <&tas6424_hi_rail>;
		standby-gpios = <&gpio1 10 GPIO_ACTIVE_LOW>;
		mute-gpios = <&gpio1 11 GPIO_ACTIVE_LOW>;
		status = "okay";
	};

	/* KSZ9896 DSA — confirm bus/address vs straps; binding: microchip,ksz.yaml */
	ksz9896_sw: switch@5f {
		compatible = "microchip,ksz9896";
		reg = <0x5f>;
		reset-gpios = <&gpio4 1 GPIO_ACTIVE_LOW>;
		interrupt-parent = <&gpio4>;
		/* Adjust edge/level if INT# polarity differs from schematic */
		interrupts = <0 IRQ_TYPE_LEVEL_LOW>;

		ethernet-ports {
			#address-cells = <1>;
			#size-cells = <0>;

			port@0 {
				reg = <0>;
				label = "lan1";
				phy-handle = <&swphy0>;
			};

			port@1 {
				reg = <1>;
				label = "lan2";
				phy-handle = <&swphy1>;
			};

			port@2 {
				reg = <2>;
				label = "lan3";
				phy-handle = <&swphy2>;
			};

			port@3 {
				reg = <3>;
				label = "lan4";
				phy-handle = <&swphy3>;
			};

			port@5 {
				reg = <5>;
				label = "cpu";
				ethernet = <&fec1>;
				phy-mode = "rgmii-txid";
				tx-internal-delay-ps = <2000>;

				fixed-link {
					speed = <1000>;
					full-duplex;
					pause;
				};
			};
		};

		mdio {
			#address-cells = <1>;
			#size-cells = <0>;

			swphy0: ethernet-phy@0 {
				reg = <0>;
				eee-broken-100tx;
				eee-broken-1000t;
			};

			swphy1: ethernet-phy@1 {
				reg = <1>;
				eee-broken-100tx;
				eee-broken-1000t;
			};

			swphy2: ethernet-phy@2 {
				reg = <2>;
				eee-broken-100tx;
				eee-broken-1000t;
			};

			swphy3: ethernet-phy@3 {
				reg = <3>;
				eee-broken-100tx;
				eee-broken-1000t;
			};
		};
	};
};

&i2c3 {
	stts22h: stts22h@3f {
		compatible = "st,stts22h";
		reg = <0x3f>;
		/* sampling-rate = <STTS22H_100Hz>; */
		status = "okay";
		interrupt-parent = <&gpio4>;
		interrupts = <8 IRQ_TYPE_LEVEL_HIGH>;
	};

	ov5640_mipi: ov5640_mipi@3c {
		status = "disabled";
	};

	pca6416: gpio@20 {
		status = "disabled";
	};

	ak4458_1: ak4458@10 {
		status = "disabled";
	};

	ak4458_2: ak4458@12 {
		status = "disabled";
	};

	ak5558: ak5558@13 {
		status = "disabled";
	};

	ak4497: ak4497@11 {
		status = "disabled";
	};

	/* BQ25792 @ 0x6b — CHGR_INT# on GPIO4_IO9 (see pinctrl_bq25792_chgr_int) */
	bq25792: bq25792@6b {
		compatible = "ti,bq25792";
		reg = <0x6b>;
		monitored-battery = <&battery_dt510>;
		interrupt-parent = <&gpio4>;
		interrupts = <9 IRQ_TYPE_LEVEL_LOW>;
		status = "okay";
	};

	/* LT9611 DSI-HDMI — disabled until display bring-up */

	lt9611: lt9611@39 {
		compatible = "lontium,lt9611";
		reg = <0x39>;
		status = "disabled";
	};

};

&sai1 {
	/* TAS6424 I2S — see pinctrl_sai1_tas6424; RXD7 is charger GPIO not SAI */
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_sai1_tas6424>;
	assigned-clocks = <&clk IMX8MM_CLK_SAI1_ROOT>;
	assigned-clock-parents = <&clk IMX8MM_AUDIO_PLL1_OUT>;
	assigned-clock-rates = <12288000>;
	fsl,sai-mclk-direction-output;
	#sound-dai-cells = <0>;
	status = "okay";
};

/* MICFIL / PDM — off (SAI1 used for TAS6424) */
&micfil {
	status = "disabled";
};

/* SAI3 — TAS2563 (Profile 8 echo path) */
&sai3 {
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_sai3>;
	assigned-clocks = <&clk IMX8MM_CLK_SAI3>;
	assigned-clock-parents = <&clk IMX8MM_AUDIO_PLL1_OUT>;
	assigned-clock-rates = <12288000>;
	fsl,sai-mclk-direction-output;
	fsl,sai-synchronous-rx;  /* RX synchronous to TX clocks */
	#sound-dai-cells = <0>;
	status = "okay";
};

/* SAI6 — TAC5301 (CPU bit/frame master) */
&sai6 {
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_sai6_tac5301>;
	assigned-clocks = <&clk IMX8MM_CLK_SAI6_ROOT>;
	assigned-clock-parents = <&clk IMX8MM_AUDIO_PLL1_OUT>;
	assigned-clock-rates = <12288000>;
	fsl,sai-mclk-direction-output;
	fsl,sai-synchronous-rx;
	#sound-dai-cells = <0>;
	status = "okay";
};

&mipi_dsi {
	status = "disabled";
};

&spdif1 {
	status = "disabled";
};

&pcie0 {
	status = "disabled";
};

/* ECSPI1 — 802.15.4 radio: PIO (no DMA); fsl,spi-rdy-drctl for ZBoss timing */
&ecspi1 {
	#address-cells = <1>;
	#size-cells = <0>;
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_ecspi1>, <&pinctrl_zigbee>;
	cs-gpios = <&gpio5 9 GPIO_ACTIVE_LOW>;
	fsl,spi-num-chipselects = <1>;
	/delete-property/ dmas;
	/delete-property/ dma-names;
	fsl,spi-rdy-drctl = <0>;
	status = "okay";

	spidev1: spi@0 {
		compatible = "rohm,dh2228fv";
		spi-max-frequency = <10000000>; /* 10 MHz — radio limit */
		spi-mode = <0>; /* SPI mode 0 */
		reg = <0>;
	};
};

/* ECSPI2 — CAN (e.g. MCP2518xx); XM125 stays on Sentai DTS */
&ecspi2 {
	status = "disabled";  /* Enable when CAN bring-up is ready */
	/delete-property/ pinctrl-names;
	/delete-property/ pinctrl-0;
};

/*
 * USB OTG1 — peripheral (gadget / lab dual-UAC2). Doc: DT510-USB-DUAL-AUDIO.md.
 * Remove role-switch: EVK ties usb1_drd_sw to deleted tcpc@50 on i2c2.
 */
&usbotg1 {
	dr_mode = "peripheral";
	status = "okay";
	/delete-property/ usb-role-switch;
	/delete-node/ port;
};

/* USDHC2 — Wi‑Fi SDIO (IW612) */
&usdhc2 {
	pinctrl-names = "default", "state_100mhz", "state_200mhz";
	pinctrl-0 = <&pinctrl_usdhc2>;
	pinctrl-1 = <&pinctrl_usdhc2_100mhz>;
	pinctrl-2 = <&pinctrl_usdhc2_200mhz>;
	bus-width = <4>;
	keep-power-in-suspend;
	non-removable;
	wakeup-source;
	max-frequency = <100000000>;
	fsl,sdio-async-interrupt-enabled;
	pm-ignore-notify;
	cap-power-off-card;
	status = "okay";

	wifi_wake_host {
		compatible = "nxp,wifi-wake-host";
		interrupt-parent = <&gpio2>;
		interrupts = <6 IRQ_TYPE_LEVEL_LOW>;  /* WL_WAKE_DEV GPIO */
		interrupt-names = "host-wake";
		wakeup-source;
	};
};

/* USDHC3 — eMMC 8-bit */
&usdhc3 {
	assigned-clocks = <&clk IMX8MM_CLK_USDHC3_ROOT>;
	assigned-clock-rates = <400000000>;
	pinctrl-names = "default", "state_100mhz", "state_200mhz";
	pinctrl-0 = <&pinctrl_usdhc3>;
	pinctrl-1 = <&pinctrl_usdhc3_100mhz>;
	pinctrl-2 = <&pinctrl_usdhc3_200mhz>;
	bus-width = <8>;
	non-removable;
	status = "okay";
};

/* USB OTG2 — cellular modem */
&usbotg2 {
	dr_mode = "host";
	status = "okay";
};
