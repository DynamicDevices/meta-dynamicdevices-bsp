/*
 * Copyright 2020 NXP
 */
/*
 * i.MX8MM Jaguar DT510 — canonical device tree source (Tier A2).
 *
 * recipes-kernel/linux/linux-lmp-fslc-imx/imx8mm-jaguar-dt510.dts is a symlink to this file (Tier A1).
 *
 * Hardware SSOT: VIX DT510 pinout / hardware spec (Google Doc — revise on schematic proof).
 * Bring-up plan & tiers: docs/DT510-BSP-PROJECT-PLAN.md
 *
 * Board highlights (this file vs EVK):
 *   PMIC: inherited PCA9450 on &i2c1 @ 0x25 (imx8mm-evkb.dts).
 *   Cellular: USB OTG2 host; LTE_RST (GPIO2_IO8), LTE_OFF / power-down (GPIO3_IO1), SIM_SEL (GPIO5_IO3: low=nano, high=eSIM) via GPIO hogs + hoggrp mux.
 *   WLAN/BT: IW612-class SDIO on USDHC2 + UART1 Bluetooth sideband; WLAN/BT wake and reset lines hogged.
 *   Ethernet: i.MX FEC → Microchip KSZ9896 DSA (RGMII + I2C management on &i2c2 @ 0x5f); four LAN PHYs inside switch.
 *   Audio: TI TAS6424 (&sai1), TAS2563 (&sai3), TAC5301 analog (&sai6, I2C @0x50 — DTS ready; ASoC driver not in factory kernel yet).
 *            TAS6424 AMP_FAULT#/WARN# on gpio-keys (GPIO1_IO12/13).
 *   Power / sensing: TI BQ25792 charger + ST STTS22H temperature on &i2c3.
 *   Zigbee: ECSPI1 to 802.15.4 module (userspace spidev); ZB_INT / ZB_RST on dedicated pads.
 *   CAN: Microchip MCP251863 on &ecspi2 (UART4 uses different pads — no mux clash); CAN_INT# GPIO4_IO16, CAN_STBY GPIO4_IO15.
 *   GNSS: u-blox NEO-M9V — GNSS_RES# on GPIO4_IO29 (SAI3_RXC mux), active-low reset driven by SoC.
 *   USB UART: Silicon Labs CP2108 quad bridge — USB enumerates with cp210x; QUART_RES# on GPIO4_IO5 (SAI1_RXD3 mux).
 *   HDMI: Lontium LT9611 on &i2c3 @ 0x39 — HDMI_RES#/INT on GPIO2 (pads shared with former WL_WAKE/ZB_RST);
 *          HDMI2C1 fault on GPIO4_IO28 (SAI3_RXFS mux). Bridge node stays disabled until DSI graph + supplies.
 *   Low-power MCU: NXP MCXC144VFM — async serial on UART4 (UART4_RXD/UART4_TXD pads; DT macros UART4_DCE_RX/TX).
 *   Digital I/O: GPIO1_IO00/01/04–09 muxed as GPIO (DI1–4 / DO1–4); IO10–IO13 reserved for TAS6424 (see &tas6424).
 *   SE050 secure element: I2C4 @ 0x48 — handled by U-Boot / OpTEE, not described here.
 *
 * I2C numbering: Linux adapter i2c-N corresponds to DTS &i2c(N+1) on this SoC (e.g. i2c-1 = &i2c2).
 */

#include "freescale/imx8mm-evkb.dts"
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>
#include <dt-bindings/interrupt-controller/irq.h>
#include <dt-bindings/clock/imx8mm-clock.h>

/ {
	model = "i.MX8MM Jaguar DT510 board";
	compatible = "fsl,imx8mm-jaguar-dt510", "fsl,imx8mm-evkb", "fsl,imx8mm-evk", "fsl,imx8mm";

	/*
	 * Drop EVK audio composites not wired on DT510 (PMIC/audio/path differs).
	 * NXP imx8mm-evk.dtsi: regulator-audio-board gates via &pca6416; sound-ak5558 / sound-ak4497
	 * reference AK codecs removed under &i2c3 — delete these too or DTC fails on dangling phandles.
	 */
	/delete-node/ sound-micfil;
	/delete-node/ sound-wm8524;
	/delete-node/ sound-ak4458;
	/delete-node/ sound-spdif;
	/delete-node/ sound-bt-sco;
	/delete-node/ regulator-audio-board;
	/delete-node/ sound-ak5558;
	/delete-node/ sound-ak4497;

	/*
	 * Fixed rails for on-board silicon:
	 *   vddext — 3V3 digital / codec DVDD where referenced.
	 *   tas6424_hi_rail — 12V class-D VBATT+PVDD net for TAS6424 (nominal; confirm vs BOM).
	 */
	vddext: regulator-vddext {
		compatible = "regulator-fixed";
		regulator-name = "VDDEXT_3V3";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
	};

	/*
	 * TAS6424 VBAT/PVDD: driver needs separate supplies; one fixed rail for both here.
	 * 12 V nominal — confirm net names vs BOM. regulator-always-on matches HW (no SW sequencing).
	 */
	tas6424_hi_rail: regulator-tas6424-hi {
		compatible = "regulator-fixed";
		regulator-name = "TAS6424_VBAT_PVDD";
		regulator-min-microvolt = <12000000>;
		regulator-max-microvolt = <12000000>;
		regulator-always-on;
	};

	/*
	 * MCP251863/MCP2518FD crystal — match BOM Hz (typ. 40 MHz); binding requires clocks + spi-max-frequency ≤ clock/2.
	 */
	can0_osc: can0-osc {
		compatible = "fixed-clock";
		#clock-cells = <0>;
		clock-frequency = <40000000>;
	};

	/* Charger IC (BQ25792) battery chemistry model — tune vs actual pack (1S placeholder). */
	battery_dt510: battery-dt510 {
		compatible = "simple-battery";
		constant-charge-voltage-max-microvolt = <4200000>;
		constant-charge-current-max-microamp = <2000000>;
		charge-term-current-microamp = <160000>;
	};

	/*
	 * ALSA device naming:
	 *   tas6424-classd — speaker power stage (TAS6424 on &sai1).
	 *   tas2563-audio — TAS2563 smart amp path on &sai3 (Profile 8 TDM).
	 */
	sound-tas6424 {
		compatible = "simple-audio-card";
		simple-audio-card,name = "tas6424-classd";
		simple-audio-card,format = "i2s";
		simple-audio-card,frame-master = <&tas6424_cpu_dai>;
		simple-audio-card,bitclock-master = <&tas6424_cpu_dai>;
		simple-audio-card,widgets =
			"Speaker", "Speaker";
		simple-audio-card,routing =
			"Speaker", "OUT";

		tas6424_cpu_dai: simple-audio-card,cpu {
			sound-dai = <&sai1>;
		};

		simple-audio-card,codec {
			sound-dai = <&tas6424>;
			clocks = <&clk IMX8MM_CLK_SAI1_ROOT>;
		};
	};

	sound-tas2563 {
		compatible = "simple-audio-card";
		simple-audio-card,name = "tas2563-audio";
		simple-audio-card,format = "i2s";
		simple-audio-card,frame-master = <&cpudai2>;
		simple-audio-card,bitclock-master = <&cpudai2>;

		simple-audio-card,widgets =
			"Speaker", "Speaker";
		simple-audio-card,routing =
			"Speaker", "OUT";

		cpudai2: simple-audio-card,cpu {
			sound-dai = <&sai3>;
			dai-tdm-slot-num = <4>;  /* Profile 8 */
			dai-tdm-slot-width = <32>;
		};

		simple-audio-card,codec {
			sound-dai = <&tas2563>;
			clocks = <&clk IMX8MM_CLK_SAI3_ROOT>;
		};
	};

	/* RDC: UART4 PDAP must be domain 0 (A53) before UART probes (see fsl,rdc-config). */
	rdc: rdc@303d0000 {
		compatible = "fsl,imx8mm-rdc";
		reg = <0x0 0x303d0000 0x0 0x10000>;
		status = "okay";

		fsl,rdc-config = <
			0x44  0x3  /* UART4 PDAP → domain 0 (A53) */
		>;
	};

	/*
	 * HDMI2C1 bridge fault (input) — not the LT9611 I2C IRQ; pad muxed in pinctrl_hdmi.
	 */
	hdmi_misc_keys {
		compatible = "gpio-keys";
		status = "okay";

		hdmi2c_fault {
			label = "hdmi2c-fault";
			gpios = <&gpio4 28 GPIO_ACTIVE_HIGH>;
			linux,code = <KEY_VENDOR>;
		};
	};

	/*
	 * TAS6424 sideband status (pads muxed with pinctrl_tas6424_gpio — codec driver still polls I2C too).
	 * BTN_0 / BTN_1 — arbitrary distinct evtest codes; labels identify nets (AMP_FAULT#, AMP_WARN# active-low).
	 */
	tas6424_amp_keys {
		compatible = "gpio-keys";
		status = "okay";

		tas6424_fault {
			label = "tas6424-fault";
			gpios = <&gpio1 12 GPIO_ACTIVE_LOW>;
			linux,code = <BTN_0>;
		};

		tas6424_warn {
			label = "tas6424-warn";
			gpios = <&gpio1 13 GPIO_ACTIVE_LOW>;
			linux,code = <BTN_1>;
		};
	};

	/* CM4: disabled — avoid resource contention with A53. */
	imx8mm-cm4 {
		compatible = "fsl,imx8mm-cm4";
		status = "disabled";
	};
};

/*
 * Pinmux (&iomuxc)
 *
 * Order matches pinctrl-0: hog GPIOs + BQ25792 charger interrupt, then groups used by drivers.
 *   hoggrp — WLAN/BT/LTE strap lines; TAS2563 reset (CODEC_SD# on GPIO5).
 *   bq25792_chgr_int — CHGR_INT# from charger (muxed GPIO4).
 *   uart1 — UART1 + UART3 pins used as RTS/CTS for Bluetooth (IW8997 sideband).
 *   uart4 — MCXC144VFM MCU serial (RDC domain programmed for A53).
 *   usdhc2 — SDIO to WLAN module (4-bit).
 *   fec1 / ksz9896_sideband — RGMII to KSZ9896; SAI1 pins repurposed as switch PME/INTR/RST GPIOs.
 *   gpio1_dio — general-purpose DIO on GPIO1_IO00/01/04–09 (pad CFG per DT510 pin tool; IO02/03 N.C. on SKU).
 *   tas6424_gpio / sai1_tas6424 — TAS6424 enable/fault GPIOs + I2S to class-D.
 *   sai2 — Not wired for audio on DT510 (pads may overlap Zigbee); pinmux retained for reference.
 *   sai3 — TAS2563 I2S + codec interrupt on GPIO5.
 *   ecspi1 + zigbee — SPI to 802.15.4 module; ZB_INT on GPIO4_IO22 (ZB_RST was GPIO2_IO11 — pad now HDMI_RES#).
 *   ecspi2 + can_gpio — MCP251863 SPI (ECSPI2); SAI1_TXD3/4 → GPIO4_IO15/16 (CAN_STBY / CAN_INT#); &sai1 uses TXD0/1 only.
 *   tac5301 — SAI6 on SAI1_RXD4/RXD5/RXD6 + SAI1_TXD5 pads; SAI1_TXD2 → GPIO4_IO14 codec strap (SAI1 TXD0/1 still &tas6424).
 *   gnss_reset — NEO-M9V GNSS_RES# (GPIO output; pad not used by &sai3 audio mux below).
 *   hdmi — LT9611 HDMI_RES# / HDMI_INT / HDMI2C1 fault (GPIO2_IO11, GPIO2_IO6, GPIO4_IO28).
 *   quart_reset — CP2108 QUART_RES# (GPIO4_IO5, SAI1_RXD3 pad; not in &sai1 TAS6424 pinctrl).
 */
&iomuxc {
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_hog>, <&pinctrl_bq25792_chgr_int>, <&pinctrl_gnss_reset>, <&pinctrl_hdmi>, <&pinctrl_quart_reset>, <&pinctrl_gpio1_dio>, <&pinctrl_ecspi2>, <&pinctrl_can_mcp2518_gpio>, <&pinctrl_sai6_tac5301>, <&pinctrl_tac5301_gpio>;

	/*
	 * Boot-time strap pins. GPIO2_IO6 / GPIO2_IO11 are reserved for HDMI (see pinctrl_hdmi); WL_WAKE host wake
	 * and SDIO wifi_wake_host nodes were removed — SDIO WLAN wake-from-sleep via that line is not available.
	 */
	pinctrl_hog: hoggrp {
		fsl,pins = <
			MX8MM_IOMUXC_SD1_DATA5_GPIO2_IO7	0x140  /* BT_WAKE_DEV */
			MX8MM_IOMUXC_SD1_DATA6_GPIO2_IO8	0x140  /* LTE_RST */
			MX8MM_IOMUXC_NAND_CE0_B_GPIO3_IO1	0x140  /* LTE_OFF / FUL_CARD_POWER_OFF# */
			MX8MM_IOMUXC_NAND_DATA01_GPIO3_IO7      0x140  /* WIFI_PD# */
			MX8MM_IOMUXC_NAND_DATA02_GPIO3_IO8	0x140  /* BT_WAKE_HOST */
			MX8MM_IOMUXC_NAND_DATA03_GPIO3_IO9      0x140  /* BT_RST# */
			MX8MM_IOMUXC_SPDIF_RX_GPIO5_IO4         0x140  /* CODEC_SD# (TAS2563 reset strap) */
			MX8MM_IOMUXC_SPDIF_TX_GPIO5_IO3         0x140  /* SIM_SEL: low=nano SIM, high=eSIM */
		>;
	};

	/* TI BQ25792 — CHGR_INT# (active-low alert from charger). */
	pinctrl_bq25792_chgr_int: bq25792_chgr_int_grp {
		fsl,pins = <
			MX8MM_IOMUXC_SAI1_RXD7_GPIO4_IO9	0x140  /* CHGR_INT# */
		>;
	};

	/*
	 * NEO-M9V GNSS — GNSS_RES# → GPIO4_IO29 (mux SAI3_RXC pad as GPIO).
	 * Hog below drives inactive (high) so module is out of reset; pulse low in userspace if needed.
	 */
	pinctrl_gnss_reset: gnssresetgrp {
		fsl,pins = <
			MX8MM_IOMUXC_SAI3_RXC_GPIO4_IO29	0x140
		>;
	};

	/*
	 * Lontium LT9611 + HDMI2C1 sideband (pads also referenced by lt9611@39 when enabled).
	 *   HDMI_RES# — GPIO2_IO11 (active-low reset out); HDMI_INT — GPIO2_IO6 (in, active-high);
	 *   HDMI2C1 fault — GPIO4_IO28 (SAI3_RXFS mux; not used by current &sai3 TAS2563 pin group).
	 */
	pinctrl_hdmi: hdmigrp {
		fsl,pins = <
			MX8MM_IOMUXC_SD1_STROBE_GPIO2_IO11	0x140
			MX8MM_IOMUXC_SD1_DATA4_GPIO2_IO6	0x140
			MX8MM_IOMUXC_SAI3_RXFS_GPIO4_IO28	0x140
		>;
	};

	/*
	 * CP2108 USB–quad-UART — QUART_RES# (active-low) on SAI1_RXD3 → GPIO4_IO5.
	 * Ports enumerate as /dev/ttyUSB* via usbserial once USB attaches (OTG host port).
	 */
	pinctrl_quart_reset: quartresetgrp {
		fsl,pins = <
			MX8MM_IOMUXC_SAI1_RXD3_GPIO4_IO5	0x140
		>;
	};

	/*
	 * General-purpose digital I/O — GPIO1_IO00/01/04–09 as GPIO (imx8mm-pinfunc.h uses …_GPIO1_IO0 …_GPIO1_IO9).
	 * Mapping vs connector: DI1–4 → IO00/01/04/05; DO1–4 → IO06–09. IO02/03 not bonded here; IO10–IO13 = &tas6424.
	 * Direction is runtime via gpiochip/libgpiod; pad configs match docs/reference/dt510-ollie-tool-generated/pin_mux.dts.
	 */
	pinctrl_gpio1_dio: gpio1diogrp {
		fsl,pins = <
			MX8MM_IOMUXC_GPIO1_IO00_GPIO1_IO0	0x114
			MX8MM_IOMUXC_GPIO1_IO01_GPIO1_IO1	0x116
			MX8MM_IOMUXC_GPIO1_IO04_GPIO1_IO4	0x116
			MX8MM_IOMUXC_GPIO1_IO05_GPIO1_IO5	0x156
			MX8MM_IOMUXC_GPIO1_IO06_GPIO1_IO6	0x116
			MX8MM_IOMUXC_GPIO1_IO07_GPIO1_IO7	0x1916
			MX8MM_IOMUXC_GPIO1_IO08_GPIO1_IO8	0x116
			MX8MM_IOMUXC_GPIO1_IO09_GPIO1_IO9	0x116
		>;
	};

	/* Bluetooth (NXP IW8997): UART1 data + UART3 pins as HCI RTS/CTS. */
	pinctrl_uart1: uart1grp {
		fsl,pins = <
			MX8MM_IOMUXC_UART1_RXD_UART1_DCE_RX     0x140
			MX8MM_IOMUXC_UART1_TXD_UART1_DCE_TX     0x140
			MX8MM_IOMUXC_UART3_TXD_UART1_DCE_RTS_B  0x140
			MX8MM_IOMUXC_UART3_RXD_UART1_DCE_CTS_B  0x140
		>;
	};

	/*
	 * UART4 — MCXC144VFM link (or lab UART): same RX/TX balls as UART4_RX/UART4_TX; NXP macros use DCE naming.
	 */
	pinctrl_uart4: uart4grp {
		fsl,pins = <
			MX8MM_IOMUXC_UART4_RXD_UART4_DCE_RX     0x140
			MX8MM_IOMUXC_UART4_TXD_UART4_DCE_TX     0x140
		>;
	};

	/* USDHC2 — Wi-Fi module SDIO (IW612 class / MAYA-W2 family). */
	pinctrl_usdhc2: usdhc2grp {
		fsl,pins = <
			MX8MM_IOMUXC_SD2_CLK_USDHC2_CLK         0x190
			MX8MM_IOMUXC_SD2_CMD_USDHC2_CMD         0x1d0
			MX8MM_IOMUXC_SD2_DATA0_USDHC2_DATA0     0x1d0
			MX8MM_IOMUXC_SD2_DATA1_USDHC2_DATA1     0x1d0
			MX8MM_IOMUXC_SD2_DATA2_USDHC2_DATA2     0x1d0
			MX8MM_IOMUXC_SD2_DATA3_USDHC2_DATA3     0x1d0
		>;
	};

	pinctrl_usdhc2_100mhz: usdhc2-100mhzgrp {
		fsl,pins = <
			MX8MM_IOMUXC_SD2_CLK_USDHC2_CLK         0x194
			MX8MM_IOMUXC_SD2_CMD_USDHC2_CMD         0x1d4
			MX8MM_IOMUXC_SD2_DATA0_USDHC2_DATA0     0x1d4
			MX8MM_IOMUXC_SD2_DATA1_USDHC2_DATA1     0x1d4
			MX8MM_IOMUXC_SD2_DATA2_USDHC2_DATA2     0x1d4
			MX8MM_IOMUXC_SD2_DATA3_USDHC2_DATA3     0x1d4
		>;
	};

	pinctrl_usdhc2_200mhz: usdhc2-200mhzgrp {
		fsl,pins = <
			MX8MM_IOMUXC_SD2_CLK_USDHC2_CLK         0x196
			MX8MM_IOMUXC_SD2_CMD_USDHC2_CMD         0x1d6
			MX8MM_IOMUXC_SD2_DATA0_USDHC2_DATA0     0x1d6
			MX8MM_IOMUXC_SD2_DATA1_USDHC2_DATA1     0x1d6
			MX8MM_IOMUXC_SD2_DATA2_USDHC2_DATA2     0x1d6
			MX8MM_IOMUXC_SD2_DATA3_USDHC2_DATA3     0x1d6
		>;
	};

	/* ENET1 — RGMII from SoC to KSZ9896 CPU port. */
	pinctrl_fec1_dt510: fec1dt510grp {
		fsl,pins = <
			MX8MM_IOMUXC_ENET_MDC_ENET1_MDC			0x116
			MX8MM_IOMUXC_ENET_MDIO_ENET1_MDIO		0x116
			MX8MM_IOMUXC_ENET_RD0_ENET1_RGMII_RD0		0x116
			MX8MM_IOMUXC_ENET_RD1_ENET1_RGMII_RD1		0x116
			MX8MM_IOMUXC_ENET_RD2_ENET1_RGMII_RD2		0x116
			MX8MM_IOMUXC_ENET_RD3_ENET1_RGMII_RD3		0x116
			MX8MM_IOMUXC_ENET_RXC_ENET1_RGMII_RXC		0x116
			MX8MM_IOMUXC_ENET_RX_CTL_ENET1_RGMII_RX_CTL	0x116
			MX8MM_IOMUXC_ENET_TD0_ENET1_RGMII_TD0		0x116
			MX8MM_IOMUXC_ENET_TD1_ENET1_RGMII_TD1		0x116
			MX8MM_IOMUXC_ENET_TD2_ENET1_RGMII_TD2		0x116
			MX8MM_IOMUXC_ENET_TD3_ENET1_RGMII_TD3		0x116
			MX8MM_IOMUXC_ENET_TXC_ENET1_RGMII_TXC		0x116
			MX8MM_IOMUXC_ENET_TX_CTL_ENET1_RGMII_TX_CTL	0x1916
		>;
	};

	/* KSZ9896 — INT#, RST#, PME# when muxed on SAI1 pads (see gpio4 / switch node). */
	pinctrl_ksz9896_sideband: ksz9896sidebandgrp {
		fsl,pins = <
			MX8MM_IOMUXC_SAI1_RXFS_GPIO4_IO0	0x116
			MX8MM_IOMUXC_SAI1_RXC_GPIO4_IO1	0x116
			MX8MM_IOMUXC_SAI1_RXD2_GPIO4_IO4	0x116
		>;
	};

	/* TAS6424 — AMP_STBY#, AMP_MUTE#, FAULT, WARN (GPIO1 sideband). */
	pinctrl_tas6424_gpio: tas6424gpiogrp {
		fsl,pins = <
			MX8MM_IOMUXC_GPIO1_IO10_GPIO1_IO10	0x116
			MX8MM_IOMUXC_GPIO1_IO11_GPIO1_IO11	0x116
			MX8MM_IOMUXC_GPIO1_IO12_GPIO1_IO12	0x116
			MX8MM_IOMUXC_GPIO1_IO13_GPIO1_IO13	0x116
		>;
	};

	/* TAS6424 — I2S master from SoC (SAI1). */
	pinctrl_sai1_tas6424: sai1tas6424grp {
		fsl,pins = <
			MX8MM_IOMUXC_SAI1_MCLK_SAI1_MCLK		0x116
			MX8MM_IOMUXC_SAI1_TXFS_SAI1_TX_SYNC		0x1916
			MX8MM_IOMUXC_SAI1_TXC_SAI1_TX_BCLK		0x116
			MX8MM_IOMUXC_SAI1_TXD0_SAI1_TX_DATA0	0x116
			MX8MM_IOMUXC_SAI1_TXD1_SAI1_TX_DATA1	0x116
		>;
	};

	/* Not used by &sai2 on DT510; kept for alignment with EVK-style SAI2 pin bundle if enabled later. */
	pinctrl_sai2: sai2grp {
		fsl,pins = <
			MX8MM_IOMUXC_SAI2_MCLK_SAI2_MCLK        0xd6
			MX8MM_IOMUXC_SAI2_TXFS_SAI2_TX_SYNC     0xd6
			MX8MM_IOMUXC_SAI2_TXC_SAI2_TX_BCLK      0xd6
			MX8MM_IOMUXC_SAI2_TXD0_SAI2_TX_DATA0    0xd6
			MX8MM_IOMUXC_SAI2_RXD0_SAI2_RX_DATA0    0xd6
		>;
	};

	/* TAS2563 — I2S + GPIO5 interrupt; SPDIF_EXT_CLK pad used as codec IRQ line. */
	pinctrl_sai3: sai3grp {
		fsl,pins = <
			MX8MM_IOMUXC_SAI3_TXFS_SAI3_TX_SYNC     0xd6
			MX8MM_IOMUXC_SAI3_TXC_SAI3_TX_BCLK      0xd6
			MX8MM_IOMUXC_SAI3_MCLK_SAI3_MCLK        0xd6
			MX8MM_IOMUXC_SAI3_TXD_SAI3_TX_DATA0     0xd6
			MX8MM_IOMUXC_SAI3_RXD_SAI3_RX_DATA0     0xd6
			MX8MM_IOMUXC_SPDIF_EXT_CLK_GPIO5_IO5    0xd6
		>;
	};

	/* ECSPI1 — SPI clock/data to Zigbee module; CS on GPIO5_IO9. */
	pinctrl_ecspi1: ecspi1grp {
		fsl,pins = <
			MX8MM_IOMUXC_ECSPI1_SS0_GPIO5_IO9	0x140
			MX8MM_IOMUXC_ECSPI1_SCLK_ECSPI1_SCLK	0x140
			MX8MM_IOMUXC_ECSPI1_MISO_ECSPI1_MISO	0x140
			MX8MM_IOMUXC_ECSPI1_MOSI_ECSPI1_MOSI	0x140
		>;
	};

	/* Zigbee — ZB_INT on GPIO4_IO22 only (GPIO2_IO11 remapped to HDMI_RES#). */
	pinctrl_zigbee: zigbeegrp {
		fsl,pins = <
			MX8MM_IOMUXC_SAI2_RXC_GPIO4_IO22        0x140
		>;
	};

	/* ECSPI2 — Microchip MCP251863 CAN controller (chip select SS0). */
	pinctrl_ecspi2: ecspi2grp {
		fsl,pins = <
			MX8MM_IOMUXC_ECSPI2_SCLK_ECSPI2_SCLK	0x140
			MX8MM_IOMUXC_ECSPI2_MISO_ECSPI2_MISO	0x140
			MX8MM_IOMUXC_ECSPI2_MOSI_ECSPI2_MOSI	0x140
			MX8MM_IOMUXC_ECSPI2_SS0_ECSPI2_SS0	0x140
		>;
	};

	/*
	 * MCP251863 sideband — CAN_STBY (active-high strap per HW doc), CAN_INT# (active-low, push/pull input).
	 * &sai1 audio mux uses TXD0/TXD1 only; TXD3/TXD4 pads → GPIO4_IO15/IO16.
	 */
	pinctrl_can_mcp2518_gpio: canmcp2518gpiogrp {
		fsl,pins = <
			MX8MM_IOMUXC_SAI1_TXD3_GPIO4_IO15	0x140
			MX8MM_IOMUXC_SAI1_TXD4_GPIO4_IO16	0x140
		>;
	};

	/*
	 * TI TAC5301-Q1 — I2S on &sai6 (pads shared naming on SAI1_* muxOptions → SAI6).
	 * No separate MCLK pad in SSOT pin list here — confirm vs BOM / driver when enabling.
	 */
	pinctrl_sai6_tac5301: sai6_tac5301_grp {
		fsl,pins = <
			MX8MM_IOMUXC_SAI1_RXD6_SAI6_TX_SYNC		0xd6
			MX8MM_IOMUXC_SAI1_RXD4_SAI6_TX_BCLK		0xd6
			MX8MM_IOMUXC_SAI1_RXD5_SAI6_TX_DATA0		0xd6
			MX8MM_IOMUXC_SAI1_TXD5_SAI6_RX_DATA0		0xd6
		>;
	};

	/* TAC5301 — configurable GPIO strap (CODEC_CTL / reset / IRQ per schematic); verify polarity vs TI tac5x1x binding. */
	pinctrl_tac5301_gpio: tac5301_gpiogrp {
		fsl,pins = <
			MX8MM_IOMUXC_SAI1_TXD2_GPIO4_IO14		0xd6
		>;
	};
};

/*
 * UART
 *   uart1 — Bluetooth HCI (88x8997 family); firmware loads over this link at init baud below.
 *   uart3 — disabled at bottom of file (unused on this SKU).
 *   uart4 — MCXC144VFM low-power MCU (RX/TX only); &rdc pins UART4 PDAP to A53 before probe (see &rdc node).
 */
&uart1 {
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_uart1>;
	assigned-clocks = <&clk IMX8MM_CLK_UART1>;
	assigned-clock-parents = <&clk IMX8MM_SYS_PLL1_80M>;
	fsl,uart-has-rtscts;
	status = "okay";

	/* Bluetooth HCI controller — MAC/PHY firmware negotiates rate after boot (see compatible). */
	bluetooth {
		compatible = "nxp,88w8997-bt";
		fw-init-baudrate = <3000000>;
	};
};

&uart4 {
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_uart4>;
	/* RDC: UART4 PDAP domain must be set in U-Boot before Linux probes this UART. */
	status = "okay";
	fsl,rdc-domain = <0>;
};

/*
 * GPIO hogs — lines that must stay at defined levels for WLAN/BT/LTE/switch wake; not runtime GPIO API.
 *   gpio2 — BT_WAKE_DEV (IO7), LTE_RST (IO8); GPIO2_IO6/IO11 = HDMI LT9611 mux — no WL_WAKE hog.
 *   gpio3 — LTE_OFF / full-card power off (IO1), WLAN PD, BT wake host + reset.
 *   gpio4 — KSZ9896 PME, GNSS_RES#, CP2108 QUART_RES#, MCP251863 CAN_STBY hog, CAN_INT# (IRQ — not hogged); TAC5301 strap GPIO4_IO14 (when codec enabled); HDMI fault; fec/switch sideband.
 *   gpio5 — SIM_SEL (IO3): output-low at boot selects nano SIM per RF shield/BOM (drive high for eSIM).
 */
&gpio2 {
	bt-wake-dev-hog {
		gpio-hog;
		gpios = <7 GPIO_ACTIVE_HIGH>;
		output-high;
		line-name = "bt-wake-dev";
	};

	/*
	 * LTE_RST — spreadsheet Active-High output from SoC; boot default released (modem out of reset).
	 * Remove gpio-hog if userspace must pulse reset during firmware upgrade.
	 */
	lte-reset-hog {
		gpio-hog;
		gpios = <8 GPIO_ACTIVE_HIGH>;
		output-low;
		line-name = "lte-reset";
	};
};

&gpio3 {
	lte-power-down-hog {
		gpio-hog;
		gpios = <1 GPIO_ACTIVE_HIGH>;
		output-low;
		line-name = "lte-power-down";
	};

	wlan-power-down-hog {
		gpio-hog;
		gpios = <7 GPIO_ACTIVE_LOW>;
		output-low;
		line-name = "wlan-power-down#";
	};
	bt-wake-host-hog {
		gpio-hog;
		gpios = <8 GPIO_ACTIVE_HIGH>;
		input;
		line-name = "bt-wake-host";
	};
	bt-reset-hog {
		gpio-hog;
		gpios = <9 GPIO_ACTIVE_LOW>;
		output-low;
		line-name = "bt-reset";
	};
};

&gpio4 {
	/* Sideband pads muxed with &fec1 / pinctrl_ksz9896_sideband — do not add gpio4 pinctrl-0 here. */
	status = "okay";

	ksz9896_pme {
		gpio-hog;
		gpios = <4 GPIO_ACTIVE_HIGH>;
		input;
		line-name = "ksz9896-ent-pme";
	};

	/*
	 * NEO-M9V GNSS_RES# — active-low reset from SoC; released high at boot.
	 * sysfs line name: gnss-res-n (GPIO4_IO29). Toggle via /sys/class/gpio or libgpiod if hog removed later.
	 */
	gnss-res-n-hog {
		gpio-hog;
		gpios = <29 GPIO_ACTIVE_LOW>;
		output-high;
		line-name = "gnss-res-n";
	};

	/* CP2108 — QUART_RES# released high at boot (active-low reset). */
	quart-res-n-hog {
		gpio-hog;
		gpios = <5 GPIO_ACTIVE_LOW>;
		output-high;
		line-name = "quart-res-n";
	};

	/*
	 * CAN transceiver standby (GPIO4_IO15) — HW labels CAN_STBY Active-High: high = standby asserted on many parts.
	 * Default output-low — typical “run” if standby is high-active; delete hog if userspace/socketcan must toggle.
	 */
	can-stby-hog {
		gpio-hog;
		gpios = <15 GPIO_ACTIVE_HIGH>;
		output-low;
		line-name = "can-stby";
	};
};

&gpio5 {
	sim-sel-hog {
		gpio-hog;
		gpios = <3 GPIO_ACTIVE_HIGH>;
		output-low;
		line-name = "sim-sel";
	};
};

/*
 * Ethernet
 *   FEC — i.MX Gigabit MAC to KSZ9896 “CPU” port over RGMII (no external PHY on FEC).
 *   Switch management — I2C on &i2c2 @ 0x5f; internal PHYs on switch MDIO (lan1–lan4).
 *   Details: docs/DT510-ETHERNET-KSZ9896.md
 */
&fec1 {
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_fec1_dt510 &pinctrl_ksz9896_sideband>;
	phy-mode = "rgmii-txid";
	status = "okay";
	/delete-property/ phy-handle;
	/delete-property/ fsl,magic-packet;

	fixed-link {
		speed = <1000>;
		full-duplex;
		pause;
	};
};

/*
 * I2C peripherals (see also file banner for Linux i2c-N vs &i2cN)
 *
 * &i2c2 (Linux i2c-1): audio ICs + KSZ9896 switch management.
 * &i2c3 (Linux i2c-2): environmental sensor + battery charger + LT9611 HDMI bridge (pins in pinctrl_hdmi).
 * PMIC &i2c1 stays in imx8mm-evkb.dts (PCA9450).
 */
&i2c2 {
	/* EVK USB-C PD controller not populated — TCPC node removed (freed 0x50). */
	/delete-node/ tcpc@50;

	/* TI TAS2563 — smart amp / speaker driver (control + diagnostics on I2C, audio on &sai3). */
	tas2563: tas2563@4c {
		#sound-dai-cells = <0>;
		compatible = "ti,tas2563";
		reg = <0x4c>;
		ti,channels = <1>;
		reset-gpios = <&gpio5 4 GPIO_ACTIVE_LOW>;
		interrupt-parent = <&gpio5>;
		interrupts = <5 IRQ_TYPE_LEVEL_LOW>;

		ti,asi-format = <0>;
		ti,left-slot = <0>;
		ti,right-slot = <1>;

		status = "okay";
	};

	/* TI TAS6424 — four-channel class-D output (I2S on &sai1). */
	tas6424: tas6424@6a {
		compatible = "ti,tas6424";
		reg = <0x6a>;
		#sound-dai-cells = <0>;
		pinctrl-names = "default";
		pinctrl-0 = <&pinctrl_tas6424_gpio>;
		dvdd-supply = <&vddext>;
		vbat-supply = <&tas6424_hi_rail>;
		pvdd-supply = <&tas6424_hi_rail>;
		standby-gpios = <&gpio1 10 GPIO_ACTIVE_LOW>;
		mute-gpios = <&gpio1 11 GPIO_ACTIVE_LOW>;
		status = "okay";
	};

	/* Microchip KSZ9896 — 4-port gigabit switch + RGMII CPU port; strap sets this I2C address. */
	ksz9896_sw: switch@5f {
		compatible = "microchip,ksz9896";
		reg = <0x5f>;
		reset-gpios = <&gpio4 1 GPIO_ACTIVE_LOW>;
		interrupt-parent = <&gpio4>;
		interrupts = <0 IRQ_TYPE_LEVEL_LOW>;

		ethernet-ports {
			#address-cells = <1>;
			#size-cells = <0>;

			port@0 {
				reg = <0>;
				label = "lan1";
				phy-handle = <&swphy0>;
			};

			port@1 {
				reg = <1>;
				label = "lan2";
				phy-handle = <&swphy1>;
			};

			port@2 {
				reg = <2>;
				label = "lan3";
				phy-handle = <&swphy2>;
			};

			port@3 {
				reg = <3>;
				label = "lan4";
				phy-handle = <&swphy3>;
			};

			port@5 {
				reg = <5>;
				label = "cpu";
				ethernet = <&fec1>;
				phy-mode = "rgmii-txid";
				tx-internal-delay-ps = <2000>;

				fixed-link {
					speed = <1000>;
					full-duplex;
					pause;
				};
			};
		};

		mdio {
			#address-cells = <1>;
			#size-cells = <0>;

			swphy0: ethernet-phy@0 {
				reg = <0>;
				eee-broken-100tx;
				eee-broken-1000t;
			};

			swphy1: ethernet-phy@1 {
				reg = <1>;
				eee-broken-100tx;
				eee-broken-1000t;
			};

			swphy2: ethernet-phy@2 {
				reg = <2>;
				eee-broken-100tx;
				eee-broken-1000t;
			};

			swphy3: ethernet-phy@3 {
				reg = <3>;
				eee-broken-100tx;
				eee-broken-1000t;
			};
		};
	};

	/*
	 * TI TAC5301-Q1 — analog audio codec on &sai6.
	 * Kernel: upstream ti,tac5x1x ASoC driver (e.g. Linux 6.10+) — not in current linux-lmp-fslc-imx line; leave disabled until driver lands.
	 * Revise reset-gpios / supplies vs datasheet + tac5x1x YAML when enabling.
	 */
	tac5301: tac5301@50 {
		compatible = "ti,tac5301";
		reg = <0x50>;
		#sound-dai-cells = <0>;
		pinctrl-names = "default";
		pinctrl-0 = <&pinctrl_tac5301_gpio>;
		reset-gpios = <&gpio4 14 GPIO_ACTIVE_LOW>;
		avdd-supply = <&vddext>;
		iovdd-supply = <&vddext>;
		status = "disabled";
	};
};

&i2c3 {
	/* Strip EVK audio/camera/gpio-expander children not fitted on DT510. */
	/delete-node/ ak4458@10;
	/delete-node/ ak4458@12;
	/delete-node/ ak5558@13;
	/delete-node/ ak4497@11;
	/delete-node/ camera@3c;
	/delete-node/ gpio@20;

	/* ST STTS22H — low-power temperature sensor (alert on GPIO4). */
	stts22h: stts22h@3f {
		compatible = "st,stts22h";
		reg = <0x3f>;
		status = "okay";
		interrupt-parent = <&gpio4>;
		interrupts = <8 IRQ_TYPE_LEVEL_HIGH>;
	};

	/* TI BQ25792 — battery charger; CHGR_INT# on GPIO4_IO9 (see pinctrl_bq25792_chgr_int). */
	bq25792: bq25792@6b {
		compatible = "ti,bq25792";
		reg = <0x6b>;
		monitored-battery = <&battery_dt510>;
		interrupt-parent = <&gpio4>;
		interrupts = <9 IRQ_TYPE_LEVEL_LOW>;
		status = "okay";
	};

	/*
	 * Lontium LT9611 — DSI→HDMI bridge. Requires regulators + DSI/MIPI graph per binding before status okay.
	 * Pins: reset GPIO2_IO11 (HDMI_RES#), IRQ GPIO2_IO6 (HDMI_INT to chip — active-high input from LT9611).
	 */
	lt9611: lt9611@39 {
		compatible = "lontium,lt9611";
		reg = <0x39>;
		status = "disabled";
		reset-gpios = <&gpio2 11 GPIO_ACTIVE_LOW>;
		interrupt-parent = <&gpio2>;
		interrupts = <6 IRQ_TYPE_LEVEL_HIGH>;
		vdd-supply = <&vddext>;
		vcc-supply = <&vddext>;
	};
};

/*
 * SAI — serial audio interfaces to codec silicon
 *   sai1 — I2S/DSP to TAS6424 (playback path).
 *   sai3 — I2S/TDM to TAS2563 (Profile 8 echo reference / smart amp data).
 */
&sai1 {
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_sai1_tas6424>;
	assigned-clocks = <&clk IMX8MM_CLK_SAI1_ROOT>;
	assigned-clock-parents = <&clk IMX8MM_AUDIO_PLL1_OUT>;
	assigned-clock-rates = <12288000>;
	fsl,sai-mclk-direction-output;
	#sound-dai-cells = <0>;
	status = "okay";
};

&sai3 {
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_sai3>;
	assigned-clocks = <&clk IMX8MM_CLK_SAI3>;
	assigned-clock-parents = <&clk IMX8MM_AUDIO_PLL1_OUT>;
	assigned-clock-rates = <12288000>;
	fsl,sai-mclk-direction-output;
	fsl,sai-synchronous-rx;
	#sound-dai-cells = <0>;
	status = "okay";
};

/*
 * Disabled — unused SKU options, EVK leftovers, or controller blocks pending driver / bring-up.
 *   uart3 — not fitted / unused on this product.
 *   sai6 — TAC5301 path (see tac5301@50); enable with ti,tac5x1x ASoC when kernel supports it.
 *   ir_recv — EVK GPIO1_IR conflicts with TAS6424 GPIO usage.
 *   reg_pcie0 / pcie0 — mini-PCIe power path not used (no M.2/NVMe on this SKU).
 *   backlight — no EVK-style LCD panel on DT510.
 *   mipi_dsi — display stack disabled until product HDMI/display bring-up.
 *   spdif1 — SPDIF not wired out for DT510 audio plan.
 */
&uart3 {
	status = "disabled";
};

&sai6 {
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_sai6_tac5301>;
	assigned-clocks = <&clk IMX8MM_CLK_SAI6_ROOT>;
	assigned-clock-parents = <&clk IMX8MM_AUDIO_PLL1_OUT>;
	assigned-clock-rates = <12288000>;
	fsl,sai-mclk-direction-output;
	fsl,sai-synchronous-rx;
	#sound-dai-cells = <0>;
	status = "disabled";
};

&ir_recv {
	status = "disabled";
};

&reg_pcie0 {
	status = "disabled";
};

&backlight {
	status = "disabled";
};

&mipi_dsi {
	status = "disabled";
};

&spdif1 {
	status = "disabled";
};

&pcie0 {
	status = "disabled";
};

/*
 * ECSPI — Zigbee / 802.15.4 radio module
 *   Hardware SPI to RF IC; userspace opens spidev for Silicon Labs ZBOSS / spinel stacks.
 *   DMA disabled so transfers stay predictable for timing-sensitive firmware reloads.
 */
&ecspi1 {
	#address-cells = <1>;
	#size-cells = <0>;
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_ecspi1>, <&pinctrl_zigbee>;
	cs-gpios = <&gpio5 9 GPIO_ACTIVE_LOW>;
	fsl,spi-num-chipselects = <1>;
	/delete-property/ dmas;
	/delete-property/ dma-names;
	fsl,spi-rdy-drctl = <0>;
	status = "okay";

	/* Generic spidev — Linux userspace talks Zigbee/NCP protocol (not a DT-bound radio driver). */
	spidev1: spi@0 {
		compatible = "rohm,dh2228fv";
		spi-max-frequency = <10000000>;
		spi-mode = <0>;
		reg = <0>;
	};
};

/*
 * ECSPI2 — Microchip MCP251863 CAN-FD controller (SPI). ECSPI2 pads are distinct from UART4 RX/TX balls on i.MX8MM.
 */
&ecspi2 {
	#address-cells = <1>;
	#size-cells = <0>;
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_ecspi2>;
	fsl,spi-num-chipselects = <1>;
	/delete-property/ dmas;
	/delete-property/ dma-names;
	status = "okay";

	can0: can@0 {
		compatible = "microchip,mcp251863", "microchip,mcp2518fd";
		reg = <0>;
		clocks = <&can0_osc>;
		spi-max-frequency = <20000000>;
		interrupt-parent = <&gpio4>;
		interrupts = <16 IRQ_TYPE_LEVEL_LOW>;
		vdd-supply = <&vddext>;
	};
};

/*
 * USB controllers
 *   usbotg1 — device-only: USB gadget (lab dual-UAC2, etc.); no TCPC so no role-switch.
 *   usbotg2 — host port for LTE/cellular modem mass-storage/diagnostic interfaces.
 */
&usbotg1 {
	dr_mode = "peripheral";
	status = "okay";
	/delete-property/ usb-role-switch;
	/delete-node/ port;
};

&usbotg2 {
	dr_mode = "host";
	status = "okay";
};

/*
 * USDHC2 — SDIO interface to WLAN module (NXP IW612 / ublox MAYA-W2 class).
 *   wifi_wake_host removed — GPIO2_IO6 muxed as HDMI_INT for LT9611 (see pinctrl_hdmi).
 */
&usdhc2 {
	pinctrl-names = "default", "state_100mhz", "state_200mhz";
	pinctrl-0 = <&pinctrl_usdhc2>;
	pinctrl-1 = <&pinctrl_usdhc2_100mhz>;
	pinctrl-2 = <&pinctrl_usdhc2_200mhz>;
	bus-width = <4>;
	keep-power-in-suspend;
	non-removable;
	wakeup-source;
	max-frequency = <100000000>;
	fsl,sdio-async-interrupt-enabled;
	pm-ignore-notify;
	cap-power-off-card;
	status = "okay";
};
