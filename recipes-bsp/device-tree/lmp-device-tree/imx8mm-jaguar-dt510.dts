/*
 * i.MX8MM Jaguar DT510 — canonical device tree source (Tier A2).
 *
 * recipes-kernel/linux/linux-lmp-fslc-imx/imx8mm-jaguar-dt510.dts is a symlink to this file (Tier A1).
 *
 * Hardware SSOT: VIX DT510 pinout / hardware spec (Google Doc, first cut — revise on schematic proof).
 * Tool-generated review material (not built): docs/reference/dt510-ollie-tool-generated/
 * Bring-up plan & tiers: docs/DT510-BSP-PROJECT-PLAN.md
 */

#include "freescale/imx8mm-evk.dts"
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/leds/common.h>
#include <dt-bindings/input/input.h>
#include <dt-bindings/interrupt-controller/irq.h>
#include <dt-bindings/clock/imx8mm-clock.h>

/ {
        model = "i.MX8MM Jaguar DT510 board";
        compatible = "fsl,imx8mm-jaguar-dt510", "fsl,imx8mm-evk", "fsl,imx8mm";

	// Regulators
	vddext: regulator-vddext {
		compatible = "regulator-fixed";
		regulator-name = "VDDEXT_3V3";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
	};

	/*
	 * TAS6424: driver requires vbat + pvdd (Linux supply names) in addition to dvdd.
	 * Single placeholder for the high-voltage amp rail — **replace voltage / topology with SSOT**
	 * (PMIC net names, separate VBAT vs PVDD, always-on vs switched) after schematic review.
	 */
	tas6424_hi_rail: regulator-tas6424-hi {
		compatible = "regulator-fixed";
		regulator-name = "TAS6424_VBAT_PVDD";
		regulator-min-microvolt = <12000000>;
		regulator-max-microvolt = <12000000>;
		regulator-always-on;
	};

	/* Tier C2: TAS6424 class-D — CPU (SAI1) is BCLK/FS master; codec is slave (driver CBC_CFC). */
	sound-tas6424 {
		compatible = "simple-audio-card";
		simple-audio-card,name = "tas6424-classd";
		simple-audio-card,format = "i2s";
		simple-audio-card,frame-master = <&tas6424_cpu_dai>;
		simple-audio-card,bitclock-master = <&tas6424_cpu_dai>;
		simple-audio-card,widgets =
			"Speaker", "Speaker";
		simple-audio-card,routing =
			"Speaker", "OUT";

		tas6424_cpu_dai: simple-audio-card,cpu {
			sound-dai = <&sai1>;
		};

		simple-audio-card,codec {
			sound-dai = <&tas6424>;
			clocks = <&clk IMX8MM_CLK_SAI1_ROOT>;
		};
	};

	sound-tas2563 {
                compatible = "simple-audio-card";
                simple-audio-card,name = "tas2563-audio";
                simple-audio-card,format = "i2s";
                simple-audio-card,frame-master = <&cpudai2>;
                simple-audio-card,bitclock-master = <&cpudai2>;
                
                // TAS2562 driver routing (simpler than TAS2781)
                // The TAS2562 driver doesn't use DMIC widgets
                simple-audio-card,widgets =
                        "Speaker", "Speaker";
                simple-audio-card,routing =
                        "Speaker", "OUT";

                cpudai2: simple-audio-card,cpu {
                        sound-dai = <&sai3>;
                        dai-tdm-slot-num = <4>;  /* Increase to 4 slots for Profile 8 */
                        dai-tdm-slot-width = <32>;
                };

                simple-audio-card,codec {
                        sound-dai = <&tas2563>;
                        clocks = <&clk IMX8MM_CLK_SAI3_ROOT>;
                };
        };

	// MICFIL Audio Configuration (for original PDM hardware)
	sound-micfil {
		compatible = "fsl,imx-audio-card";
		model = "micfil-audio";
		status = "disabled"; /* &micfil off — SAI1 muxed for TAS6424 per SSOT */
		pri-dai-link {
			link-name = "micfil hifi";
			format = "i2s";
			cpu {
				sound-dai = <&micfil>;
			};
		};
	};

	sound-wm8524 {
		status = "disabled";
	};

	sound-ak4458 {
		status = "disabled";
	};

	sound-spdif {
		status = "disabled";
	};

	sound-bt-sco {
		status = "disabled";
	};

	// Disable M4 core to prevent resource conflicts
	imx8mm-cm4 {
		compatible = "fsl,imx8mm-cm4";
		status = "disabled";
	};

	// RDC configuration for UART4 resource assignment
	// This ensures UART4 is properly assigned to A53 domain before UART driver probes
	rdc: rdc@303d0000 {
		compatible = "fsl,imx8mm-rdc";
		reg = <0x0 0x303d0000 0x0 0x10000>;
		status = "okay";
		
		// Configure UART4 for A53 domain (domain 0) access
		// This must complete before serial driver initialization
		fsl,rdc-config = <
			0x44  0x3  // UART4 PDAP: Domain 0 (A53) read/write access
		>;
	};

	sw-keys {
                compatible = "gpio-keys";
		status = "enabled";

                sw1: key-act {
                        label = "Key Act";
                        linux,code = <BTN_SELECT>;
                        gpios = <&gpio3 6 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
			interrupt-parent = <&gpio3>;
			interrupt = <6 IRQ_TYPE_EDGE_FALLING>;
                };
	};

	/* Tier B1: BQ25792 monitored-battery model — tune from SSOT / pack (1S placeholder). */
	battery_dt510: battery-dt510 {
		compatible = "simple-battery";
		constant-charge-voltage-max-microvolt = <4200000>;
		constant-charge-current-max-microamp = <2000000>;
		charge-term-current-microamp = <160000>;
	};
};

&iomuxc {
        pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_hog>;

	// TODO: Break these out better?
	pinctrl_hog: hoggrp {
		fsl,pins = <
			MX8MM_IOMUXC_SD1_DATA4_GPIO2_IO6	0x140  // WL_WAKE_DEV
			MX8MM_IOMUXC_SD1_DATA5_GPIO2_IO7	0x140  // BT_WAKE_DEV
			MX8MM_IOMUXC_SD1_DATA6_GPIO2_IO8	0x000  // LTE_RESET
			MX8MM_IOMUXC_NAND_CE0_B_GPIO3_IO1	0x140  // FUL_CARD_POWER_OFF#
                        MX8MM_IOMUXC_NAND_DATA01_GPIO3_IO7      0x140  // WIFI_PD#
			MX8MM_IOMUXC_NAND_DATA02_GPIO3_IO8	0x140  // BT_WAKE_HOST
                        MX8MM_IOMUXC_NAND_DATA03_GPIO3_IO9      0x140  // BT_RST#
			/* SAI1_RXD4 / RXD7 / TXFS: removed — SSOT muxes these for SAI1/SAI6 TAS6424 path (see pinctrl_sai1_tas6424) */
                        MX8MM_IOMUXC_SPDIF_RX_GPIO5_IO4         0x140  // CODEC_SD#
			// ZB_INT and ZB_RST# removed from hog - managed by ZBoss muxer
		>;
	};

	// Zigbee GPIO pins - not hogged, available for ZBoss muxer
	pinctrl_zigbee: zigbeegrp {
		fsl,pins = <
			MX8MM_IOMUXC_SAI2_RXC_GPIO4_IO22        0x140  // ZB_INT
			MX8MM_IOMUXC_SD1_STROBE_GPIO2_IO11      0x140  // ZB_RST#
		>;
	};

        pinctrl_ecspi1: ecspi1grp {
                fsl,pins = <
			MX8MM_IOMUXC_ECSPI1_SS0_GPIO5_IO9	0x140  // Increased drive strength
                        MX8MM_IOMUXC_ECSPI1_SCLK_ECSPI1_SCLK	0x140  // Increased drive strength
                        MX8MM_IOMUXC_ECSPI1_MISO_ECSPI1_MISO	0x140  // Increased drive strength
                        MX8MM_IOMUXC_ECSPI1_MOSI_ECSPI1_MOSI	0x140  // Increased drive strength
                >;
        };

        /* Legacy Sentai XM125 radar pinctrl — unused on DT510 (XM125 disabled); retained for DTS compatibility */
        pinctrl_xm125_radar: xm125_radar_grp {
                fsl,pins = <
                        /* Bootloader control (BOOT0) - repurpose ECSPI2_SS0 as GPIO */
                        MX8MM_IOMUXC_ECSPI2_SS0_GPIO5_IO13      0x96
                        /* Reset control (active-low) - same pin as BGT radar reset */
                        MX8MM_IOMUXC_SAI3_RXFS_GPIO4_IO28       0x96
                        /* Wake up control (assert high to wake up) - repurpose ECSPI2_MOSI */
                        MX8MM_IOMUXC_ECSPI2_MOSI_GPIO5_IO11     0x96
                        /* MCU interrupt input - repurpose SAI3_RXC */
                        MX8MM_IOMUXC_SAI3_RXC_GPIO4_IO29        0x96
                        /* Disable unused SPI pins - hardware team feedback: 
                         * SCLK and MISO just go to test points on radar board, not used by XM125 */
                        MX8MM_IOMUXC_ECSPI2_SCLK_GPIO5_IO10     0x96
                        MX8MM_IOMUXC_ECSPI2_MISO_GPIO5_IO12     0x96
                >;
        };

	pinctrl_pdm: pdmgrp {
		fsl,pins = <
			MX8MM_IOMUXC_SAI1_MCLK_PDM_CLK		0xd6
			MX8MM_IOMUXC_SAI1_RXD0_PDM_DATA0	0xd6
			MX8MM_IOMUXC_SAI1_RXD1_PDM_DATA1	0xd6
			MX8MM_IOMUXC_SAI1_RXD2_PDM_DATA2	0xd6
			MX8MM_IOMUXC_SAI1_RXD3_PDM_DATA3	0xd6
		>;
	};

        pinctrl_sai2: sai2grp {
                fsl,pins = <
                        MX8MM_IOMUXC_SAI2_MCLK_SAI2_MCLK        0xd6
                        MX8MM_IOMUXC_SAI2_TXFS_SAI2_TX_SYNC     0xd6
                        MX8MM_IOMUXC_SAI2_TXC_SAI2_TX_BCLK      0xd6
                        MX8MM_IOMUXC_SAI2_TXD0_SAI2_TX_DATA0    0xd6
                        MX8MM_IOMUXC_SAI2_RXD0_SAI2_RX_DATA0    0xd6
                >;
        };

        pinctrl_sai3: sai3grp {
                fsl,pins = <
                        MX8MM_IOMUXC_SAI3_TXFS_SAI3_TX_SYNC     0xd6    // Frame sync
                        MX8MM_IOMUXC_SAI3_TXC_SAI3_TX_BCLK      0xd6    // Bit clock
                        MX8MM_IOMUXC_SAI3_MCLK_SAI3_MCLK        0xd6    // Master clock
                        MX8MM_IOMUXC_SAI3_TXD_SAI3_TX_DATA0     0xd6    // Transmit (playback)
                        MX8MM_IOMUXC_SAI3_RXD_SAI3_RX_DATA0     0xd6    // Receive (from TAS2563 mics)
                        MX8MM_IOMUXC_SPDIF_EXT_CLK_GPIO5_IO5    0xd6    // Audio codec interrupt
                >;
        };

	/* Tier C2 step 1 — TAS6424 on SAI1: align with docs/reference/dt510-ollie-tool-generated/pin_mux.dts (BOARD_InitPins) */
	pinctrl_sai1_tas6424: sai1tas6424grp {
		fsl,pins = <
			MX8MM_IOMUXC_SAI1_MCLK_SAI1_MCLK		0xd6
			MX8MM_IOMUXC_SAI1_RXC_GPIO4_IO1			0xd6
			MX8MM_IOMUXC_SAI1_RXD2_GPIO4_IO4		0xd6
			MX8MM_IOMUXC_SAI1_RXD3_GPIO4_IO5		0xd6
			MX8MM_IOMUXC_SAI1_RXD4_SAI6_TX_BCLK		0xd6
			MX8MM_IOMUXC_SAI1_RXD5_SAI6_TX_DATA0		0xd6
			MX8MM_IOMUXC_SAI1_RXD6_SAI6_TX_SYNC		0xd6
			MX8MM_IOMUXC_SAI1_RXD7_GPIO4_IO9		0xd6
			MX8MM_IOMUXC_SAI1_RXFS_GPIO4_IO0		0xd6
			MX8MM_IOMUXC_SAI1_TXC_SAI1_TX_BCLK		0xd6
			MX8MM_IOMUXC_SAI1_TXD0_SAI1_TX_DATA0		0xd6
			MX8MM_IOMUXC_SAI1_TXD1_SAI1_TX_DATA1		0xd6
			MX8MM_IOMUXC_SAI1_TXD2_GPIO4_IO14		0xd6
			MX8MM_IOMUXC_SAI1_TXD3_GPIO4_IO15		0xd6
			MX8MM_IOMUXC_SAI1_TXD4_GPIO4_IO16		0xd6
			MX8MM_IOMUXC_SAI1_TXD5_SAI6_RX_DATA0		0xd6
			MX8MM_IOMUXC_SAI1_TXD6_GPIO4_IO18		0xd6
			MX8MM_IOMUXC_SAI1_TXFS_SAI1_TX_SYNC		0xd6
		>;
	};

        pinctrl_uart1: uart1grp {
                fsl,pins = <
                        MX8MM_IOMUXC_UART1_RXD_UART1_DCE_RX     0x140
                        MX8MM_IOMUXC_UART1_TXD_UART1_DCE_TX     0x140
                        MX8MM_IOMUXC_UART3_TXD_UART1_DCE_RTS_B  0x140
                        MX8MM_IOMUXC_UART3_RXD_UART1_DCE_CTS_B  0x140
                >;
        };

        pinctrl_uart4: uart4grp {
                fsl,pins = <
                        MX8MM_IOMUXC_UART4_RXD_UART4_DCE_RX     0x140
                        MX8MM_IOMUXC_UART4_TXD_UART4_DCE_TX     0x140
                >;
        };

        pinctrl_usdhc2: usdhc2grp {
                fsl,pins = <
                        MX8MM_IOMUXC_SD2_CLK_USDHC2_CLK         0x190
                        MX8MM_IOMUXC_SD2_CMD_USDHC2_CMD         0x1d0
                        MX8MM_IOMUXC_SD2_DATA0_USDHC2_DATA0     0x1d0
                        MX8MM_IOMUXC_SD2_DATA1_USDHC2_DATA1     0x1d0
                        MX8MM_IOMUXC_SD2_DATA2_USDHC2_DATA2     0x1d0
                        MX8MM_IOMUXC_SD2_DATA3_USDHC2_DATA3     0x1d0
                >;
        };

        pinctrl_usdhc2_100mhz: usdhc2-100mhzgrp {
                fsl,pins = <
                        MX8MM_IOMUXC_SD2_CLK_USDHC2_CLK         0x194
                        MX8MM_IOMUXC_SD2_CMD_USDHC2_CMD         0x1d4
                        MX8MM_IOMUXC_SD2_DATA0_USDHC2_DATA0     0x1d4
                        MX8MM_IOMUXC_SD2_DATA1_USDHC2_DATA1     0x1d4
                        MX8MM_IOMUXC_SD2_DATA2_USDHC2_DATA2     0x1d4
                        MX8MM_IOMUXC_SD2_DATA3_USDHC2_DATA3     0x1d4
                >;
        };

        pinctrl_usdhc2_200mhz: usdhc2-200mhzgrp {
                fsl,pins = <
                        MX8MM_IOMUXC_SD2_CLK_USDHC2_CLK         0x196
                        MX8MM_IOMUXC_SD2_CMD_USDHC2_CMD         0x1d6
                        MX8MM_IOMUXC_SD2_DATA0_USDHC2_DATA0     0x1d6
                        MX8MM_IOMUXC_SD2_DATA1_USDHC2_DATA1     0x1d6
                        MX8MM_IOMUXC_SD2_DATA2_USDHC2_DATA2     0x1d6
                        MX8MM_IOMUXC_SD2_DATA3_USDHC2_DATA3     0x1d6
                >;
        };
};

&uart1 { /* BT */
        pinctrl-names = "default";
        pinctrl-0 = <&pinctrl_uart1>;
        assigned-clocks = <&clk IMX8MM_CLK_UART1>;
        assigned-clock-parents = <&clk IMX8MM_SYS_PLL1_80M>;
        fsl,uart-has-rtscts;
        status = "okay";

        bluetooth {
                compatible = "nxp,88w8997-bt";
		fw-init-baudrate = <3000000>;
        };
};

&uart3 {
	status = "disabled";
};

&uart4 {
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_uart4>;
	status = "okay";  /* Safe to enable - RDC assignment handled by U-Boot before kernel boot */
	
	// UART4 RDC assignment is now handled by U-Boot bootcmd before kernel starts
	// This prevents the synchronous external abort during early boot
	fsl,rdc-domain = <0>;  // Assign to A53 domain
};

&gpio2 {
	wl-wake-dev-hog {
		gpio-hog;
		gpios = <6 GPIO_ACTIVE_HIGH>;
		output-high;
		line-name = "wl-wake-dev";
	};
	bt-wake-dev-hog {
		gpio-hog;
		gpios = <7 GPIO_ACTIVE_HIGH>;
		output-high;
		line-name = "bt-wake-dev";
	};
//        zb-reset-hog {
//                gpio-hog;
//                gpios = <11 GPIO_ACTIVE_LOW>;
//                output-low;
//                line-name = "zb-reset";
//        };
};

&gpio3 {
	lte-power-down-hog {
		gpio-hog;
		gpios = <1 GPIO_ACTIVE_HIGH>;
		output-low;
		line-name = "lte-power-down";
	};

	wlan-power-down-hog {
		gpio-hog;
		gpios = <7 GPIO_ACTIVE_LOW>;
		output-low;
		line-name = "wlan-power-down#";
	};
	bt-wake-host-hog {
		gpio-hog;
		gpios = <8 GPIO_ACTIVE_HIGH>;
		input;
		line-name = "bt-wake-host";
	};
	bt-reset-hog {
		gpio-hog;
		gpios = <9 GPIO_ACTIVE_LOW>;
		output-low;
		line-name = "bt-reset";
	};
};

//&gpio4 {
//       zb-int-hog {
//		gpio-hog;
//		gpios = <22 GPIO_ACTIVE_HIGH>;
//		input;
//		line-name = "zb-int";
//       };
//};

&gpio5 {
       audio-shutdown-hog {
		gpio-hog;
		gpios = <4 GPIO_ACTIVE_LOW>;
		output-low;
		line-name = "tas2563-shutdown";
       };
};

&fec1 {
        status = "disabled";
};

&i2c1 {
	sht40: sht40@44 {
		compatible = "sensirion,sht4x";
                reg = <0x44>;
		status = "okay";
	};
};

&i2c2 {
	/*
	 * imx8mm-evk.dts (included) defines tcpc@50 (PTN5110 TCPC). DT510 does not populate it;
	 * remove the inherited node so I2C2 @ 0x50 is free for TAC5301 (Tier C2) per SSOT.
	 */
	/delete-node/ tcpc@50;

	/* TAC5301 @ 0x50 per SSOT — address free after delete-node above. */

	// Audio Amp with Dual Hardware Support
        tas2563: tas2563@4C {
                #sound-dai-cells = <0>;
                compatible = "ti,tas2563";
                reg = <0x4C>;
                ti,channels = <1>; /* channel number */
                reset-gpios = <&gpio5 4 GPIO_ACTIVE_LOW>;   /* Enable reset control - active low */
                interrupt-parent = <&gpio5>;
                interrupts = <5 IRQ_TYPE_LEVEL_LOW>;
                
                // Basic I2S Configuration for TAS2562 driver
                ti,asi-format = <0>; /* 0=I2S format */
                ti,left-slot = <0>; /* Left audio channel */
                ti,right-slot = <1>; /* Right audio channel */
                
                // TAS2562 driver does not support PDM microphones
                // Use MICFIL for microphone input instead
                
                status = "okay";
        };

	/*
	 * TAS6424E-Q1 @ 0x6A — class-D on SAI1 (Tier C2).
	 * standby-gpios / mute-gpios: add when AMP_STBY# / AMP_MUTE# are confirmed in SSOT (optional in driver).
	 */
	tas6424: tas6424@6a {
		compatible = "ti,tas6424";
		reg = <0x6a>;
		#sound-dai-cells = <0>;
		dvdd-supply = <&vddext>;
		vbat-supply = <&tas6424_hi_rail>;
		pvdd-supply = <&tas6424_hi_rail>;
		status = "okay";
	};
};

&i2c3 {
	stts22h: stts22h@3F {
		compatible = "st,stts22h";
                reg = <0x3f>;
//		sampling-rate = <STTS22H_100Hz>;
		status = "okay";
		interrupt-parent = <&gpio4>;
		interrupts = <8 IRQ_TYPE_LEVEL_HIGH>;
	};

	led-controller@28 {
            #address-cells = <1>;
            #size-cells = <0>;
            compatible = "ti,lp5024";
            reg = <0x28>;
            enable-gpios = <&gpio4 9 GPIO_ACTIVE_HIGH>;

            multi-led@0 {
                #address-cells = <1>;
                #size-cells = <0>;
		label = "led5";
                reg = <0>;
//                default-intensity = <100 0 0>;
                color = <LED_COLOR_ID_RGB>;
                function = LED_FUNCTION_INDICATOR;
                led@0 {
                     reg = <0>;
                     color = <LED_COLOR_ID_RED>;
                };

                led@1 {
                     reg = <1>;
                     color = <LED_COLOR_ID_GREEN>;
                };

                led@2 {
                     reg = <2>;
                     color = <LED_COLOR_ID_BLUE>;
                };
            };

            multi-led@1 {
                #address-cells = <1>;
                #size-cells = <0>;
		label = "led1";
                reg = <1>;
//                default-intensity = <100 0 0>;
                color = <LED_COLOR_ID_RGB>;
                function = LED_FUNCTION_INDICATOR;
                led@0 {
                     reg = <12>;
                     color = <LED_COLOR_ID_RED>;
                };

                led@1 {
                     reg = <13>;
                     color = <LED_COLOR_ID_GREEN>;
                };

                led@2 {
                     reg = <14>;
                     color = <LED_COLOR_ID_BLUE>;
                };
            };

	    multi-led@2 {
                #address-cells = <1>;
                #size-cells = <0>;
		label = "led2";
                reg = <2>;
//                default-intensity = <100 0 0>;
                color = <LED_COLOR_ID_RGB>;
                function = LED_FUNCTION_INDICATOR;
                led@0 {
                     reg = <15>;
                     color = <LED_COLOR_ID_RED>;
                };

                led@1 {
                     reg = <16>;
                     color = <LED_COLOR_ID_GREEN>;
                };

                led@2 {
                     reg = <17>;
                     color = <LED_COLOR_ID_BLUE>;
                };
            };

            multi-led@3 {
                #address-cells = <1>;
                #size-cells = <0>;
		label = "led3";
                reg = <3>;
//                default-intensity = <100 0 0>;
                color = <LED_COLOR_ID_RGB>;
                function = LED_FUNCTION_INDICATOR;
                led@0 {
                     reg = <3>;
                     color = <LED_COLOR_ID_RED>;
                };

                led@1 {
                     reg = <4>;
                     color = <LED_COLOR_ID_GREEN>;
                };

                led@2 {
                     reg = <5>;
                     color = <LED_COLOR_ID_BLUE>;
                };
            };

            multi-led@4 {
                #address-cells = <1>;
                #size-cells = <0>;
		label = "led4";
                reg = <4>;
//                default-intensity = <100 0 0>;
                color = <LED_COLOR_ID_RGB>;
                function = LED_FUNCTION_INDICATOR;
                led@0 {
                     reg = <6>;
                     color = <LED_COLOR_ID_RED>;
                };

                led@1 {
                     reg = <7>;
                     color = <LED_COLOR_ID_GREEN>;
                };

                led@2 {
                     reg = <8>;
                     color = <LED_COLOR_ID_BLUE>;
                };
            };

            multi-led@5 {
                #address-cells = <1>;
                #size-cells = <0>;
		label = "led0";
                reg = <5>;
//                default-intensity = <100 0 0>;
                color = <LED_COLOR_ID_RGB>;
                function = LED_FUNCTION_INDICATOR;
                led@0 {
                     reg = <9>;
                     color = <LED_COLOR_ID_RED>;
                };

                led@1 {
                     reg = <10>;
                     color = <LED_COLOR_ID_GREEN>;
                };

                led@2 {
                     reg = <11>;
                     color = <LED_COLOR_ID_BLUE>;
                };
            };
        };

	ov5640_mipi: ov5640_mipi@3c {
		status = "disabled";
	};

	pca6416: gpio@20 {
		status = "disabled";
	};

        ak4458_1: ak4458@10 {
		status = "disabled";
	};

        ak4458_2: ak4458@12 {
		status = "disabled";
	};

        ak5558: ak5558@13 {
		status = "disabled";
	};

        ak4497: ak4497@11 {
		status = "disabled";
	};

        /* XM125: Sentai board only — not populated on DT510; keep node disabled for I2C addr documentation */
        xm125: xm125@52 {
                compatible = "acconeer,xm125";
                reg = <0x52>;
                pinctrl-names = "default";
                pinctrl-0 = <&pinctrl_xm125_radar>;
                status = "disabled";
        };

	/* Tier B1: BQ25792 @ 0x6B on I2C3 — Ollie confirmed address. Add CHGR_INT# when GPIO is in SSOT. */
	bq25792: bq25792@6b {
		compatible = "ti,bq25792";
		reg = <0x6b>;
		monitored-battery = <&battery_dt510>;
		/* interrupt-parent / interrupts: wire CHGR_INT# (active-low pulse per TI) when confirmed */
		status = "okay";
	};

	/* SSOT placeholder (disabled): enable Tier C3 after probe + pinctrl validation */

	lt9611: lt9611@39 {
		compatible = "lontium,lt9611";
		reg = <0x39>;
		status = "disabled";
	};

};

&sai1 {
	/* TAS6424 I2S/TDM to class-D — SSOT pinmux in pinctrl_sai1_tas6424 (tool-generated BOARD_InitPins); not PDM on these balls */
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_sai1_tas6424>;
	assigned-clocks = <&clk IMX8MM_CLK_SAI1_ROOT>;
	assigned-clock-parents = <&clk IMX8MM_AUDIO_PLL1_OUT>;
	assigned-clock-rates = <12288000>;
	fsl,sai-mclk-direction-output;
	#sound-dai-cells = <0>;
	status = "okay";
};

/* PDM: prior mux used SAI1 pins for MICFIL — conflicts with TAS6424 SSOT; leave off until a product variant needs PDM on another block */
&micfil {
	status = "disabled";
};

// Enhanced SAI3 configuration for bidirectional audio (Profile 8 echo reference)
&sai3 {
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_sai3>;
	assigned-clocks = <&clk IMX8MM_CLK_SAI3>;
	assigned-clock-parents = <&clk IMX8MM_AUDIO_PLL1_OUT>;
	assigned-clock-rates = <12288000>;
	fsl,sai-mclk-direction-output;
	fsl,sai-synchronous-rx;  /* RX uses TX clocks for synchronized operation */
	#sound-dai-cells = <0>;
	status = "okay";
};

&mipi_dsi {
       status = "disabled";
};

&spdif1 {
       status = "disabled";
};

&pcie0 {
       status = "disabled";
};

// 802.15.4
&ecspi1 {
	#address-cells = <1>;
	#size-cells = <0>;
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_ecspi1>, <&pinctrl_zigbee>;
	cs-gpios = <&gpio5 9 GPIO_ACTIVE_LOW>;
        fsl,spi-num-chipselects = <1>;
        // Force PIO mode by removing DMA properties entirely
        /delete-property/ dmas;
        /delete-property/ dma-names;
        // Increase timeout for SPI transfers
        fsl,spi-rdy-drctl = <0>;
        // Re-enable burst mode - zb_mux expects 16-byte offset
        // fsl,spi-disable-burst;
	status = "okay";

        spidev1: spi@0 {
		compatible = "rohm,dh2228fv";
                spi-max-frequency = <10000000>; // 10MHz - maximum radio spec limit
                spi-mode = <0>;                 // SPI Mode 0 (CPOL=0, CPHA=0)
                reg = <0>;
        };
};

// ECSPI2: available for SSOT CAN (MCP2518xx) on DT510 — not used for XM125 on this board
&ecspi2 {
	status = "disabled";  /* Enable when CAN bring-up is ready */
	/delete-property/ pinctrl-names;
	/delete-property/ pinctrl-0;
};

&flexspi {
	status = "disabled";
};

/* USB OTG1: peripheral mode for USB gadget / lab dual-UAC2 (see DT510-USB-DUAL-AUDIO.md).
 * No STUSB4500 USB-PD controller on DT510 — not USB-C powered; no TCPC. Sentai-only PD path.
 */
&usbotg1 {
	dr_mode = "peripheral";
        status = "okay";
};

// WiFi SDIO Interface - IW612 module with power management
&usdhc2 {
	pinctrl-names = "default", "state_100mhz", "state_200mhz";
	pinctrl-0 = <&pinctrl_usdhc2>;
	pinctrl-1 = <&pinctrl_usdhc2_100mhz>;
	pinctrl-2 = <&pinctrl_usdhc2_200mhz>;
	bus-width = <4>;
	keep-power-in-suspend;
	non-removable;
	wakeup-source;
	max-frequency = <100000000>;
	fsl,sdio-async-interrupt-enabled;
	pm-ignore-notify;
	cap-power-off-card;
	status = "okay";

	wifi_wake_host {
		compatible = "nxp,wifi-wake-host";
		interrupt-parent = <&gpio2>;
		interrupts = <6 IRQ_TYPE_LEVEL_LOW>;  /* WL_WAKE_DEV GPIO */
		interrupt-names = "host-wake";
		wakeup-source;
	};
};

// Cellular modem
&usbotg2 {
	dr_mode = "host";
        status = "okay";
};
