From: BSP integration <dev@localhost>
Subject: [PATCH] ASoC: tac5x1x: add TI TAC5301-Q1 compatible

TI posted tac5x1x-i2c omits TAC5301-Q1; DT510 binds `compatible = "ti,tac5301"`.
Mirror all TAC5311 mono codec paths for TAC5301.

Signed-off-by: BSP integration <dev@localhost>

---
 sound/soc/codecs/tac5x1x-i2c.c | 10 ++++++++++
 sound/soc/codecs/tac5x1x.h     |  1 +
 2 files changed, 11 insertions(+)

diff --git a/sound/soc/codecs/tac5x1x-i2c.c b/sound/soc/codecs/tac5x1x-i2c.c
--- a/sound/soc/codecs/tac5x1x-i2c.c
+++ b/sound/soc/codecs/tac5x1x-i2c.c
@@ -1477,6 +1477,7 @@ static s32 tac5x1x_add_controls(struct snd_soc_component *component)
 		if (ret)
 			return ret;
 	fallthrough;
+	case TAC5301:
 	case TAC5311:
 	case TAC5411:
 		ret =
@@ -1547,6 +1548,7 @@ static s32 tac5x1x_add_ip_diag_controls(struct snd_soc_component *component)
 	switch (tac5x1x->codec_type) {
 	case TAA5212:
 		break;
 	case TAA5412:
+	case TAC5301:
 	case TAC5311:
 	case TAC5312:
 	case TAC5411:
@@ -1616,6 +1618,7 @@ static s32 tac5x1x_add_widgets(struct snd_soc_component *component)
 	switch (tac5x1x->codec_type) {
 	case TAC5111:
 	case TAC5211:
+	case TAC5301:
 	case TAC5311:
 	case TAC5411:
 		ret =
@@ -2003,6 +2006,7 @@ static s32 tac5x1x_parse_dt(struct tac5x1x_priv *tac5x1x,
 		break;
 	case TAA5412:
+	case TAC5301:
 	case TAC5411:
 	case TAC5412:
 	case TAC5311:
@@ -2137,6 +2141,7 @@ static s32 tac5x1x_probe(struct device *dev, struct regmap *regmap,
 	case TAC5112:
 	case TAC5211:
 	case TAC5212:
+	case TAC5301:
 	case TAC5311:
 	case TAC5312:
 	case TAC5411:
@@ -2181,6 +2186,7 @@ static const struct of_device_id tac5x1x_of_match[] = {
 	{ .compatible = "ti,tac5211", .data = (void *)TAC5211 },
 	{ .compatible = "ti,tac5212", .data = (void *)TAC5212 },
+	{ .compatible = "ti,tac5301", .data = (void *)TAC5301 },
 	{ .compatible = "ti,tac5311", .data = (void *)TAC5311 },
 	{ .compatible = "ti,tac5312", .data = (void *)TAC5312 },
 	{ .compatible = "ti,tac5411", .data = (void *)TAC5411 },
@@ -2198,6 +2204,7 @@ static const struct i2c_device_id tac5x1x_id[] = {
 	{"tac5211", TAC5211},
 	{"tac5212", TAC5212},
+	{"tac5301", TAC5301},
 	{"tac5311", TAC5311},
 	{"tac5312", TAC5312},
 	{"tac5411", TAC5411},
diff --git a/sound/soc/codecs/tac5x1x.h b/sound/soc/codecs/tac5x1x.h
--- a/sound/soc/codecs/tac5x1x.h
+++ b/sound/soc/codecs/tac5x1x.h
@@ -2541,6 +2541,7 @@ enum tac5x1x_type {
 	TAC5211,
 	TAC5212,
+	TAC5301,
 	TAC5311,
 	TAC5312,
 	TAC5411,
